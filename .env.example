# Anthropic API key — required for AI analysis
ANTHROPIC_API_KEY=sk-ant-...

# Google Sheets embed URL — required for the inline matrix panel
# How to get this:
#   1. Open your Google Sheet
#   2. File → Share → Publish to web
#   3. Select "Entire document" and "Web page", then click Publish
#   4. Copy the link shown — it will look like:
#      https://docs.google.com/spreadsheets/d/SHEET_ID/pubhtml
#   5. To embed a specific sheet, append: ?gid=SHEET_GID&single=true&widget=true&headers=false
#      e.g. https://docs.google.com/spreadsheets/d/SHEET_ID/pubhtml?gid=0&single=true&widget=true&headers=false
NEXT_PUBLIC_SHEETS_EMBED_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/pubhtml?widget=true&headers=false
