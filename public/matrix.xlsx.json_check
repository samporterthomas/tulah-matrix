[{"Brand / Expression":"Clinique La Prairie, Montreux","Operator / Hosted Within":"\u2014","Level / Category":"A \u2014 Mothership","Status":"Established","Location City, Country":"Clarens (Montreux), Switzerland","Core Positioning":"Medical Longevity","Target Segments":"UHNW, Medical Tourism, HNW","Price Tier (1-5)":"5","Est":"1931","Description":"Founded in 1931, Clinique La Prairie is a standalone luxury medical wellness campus in Montreux combining a 5-star hotel (38 keys), a full medical centre with 50+ specialist physicians and 3 operating theatres, a 1,600 m\u00b2 longevity spa, and an on-site medical imaging centre and laboratory \u2014 delivering week-long preventive-medicine and longevity programmes.","Does the hotel have a separate spa? (0/1)":"\u2014","Target Audiences":"Medical Recovery, High Performance, Individual Wellness","Clinical Grade (1\u20135)":"5","Residential (0/1)":"1","Hotel Guest (0/1)":"0","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"250583.83","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"59200","Clinical & Treatment Rooms":"65","Clinical & Treatment Rooms Detail":"Surgical \u2014 3 (3 operating theatres)\n\nPost-operative / Recovery \u2014 26 (20 standard recovery rooms, 2 junior suites, 4 medical suites)\n\nSpa & Aesthetic Treatment \u2014 29 (18 spa treatment cabins, 11 aesthetic treatment rooms)\n\nMedical Imaging \u2014 7 (1 MRI, 1 CT, 1 mammography, 1 ultrasound, 1 digital radiology, 1 DXA, 1 orthopantomogram)\n\n\nMain Sources Used:\n\nClinique La Prairie (official website) \u2013 Spa &\u2026","No. of Specialist Facilities":"40","Specialist Facilities/Equipment":"Diagnostics & Imaging (17)\n3 Tesla MRI; 64-slice CT scanner; low-dose digital mammography with 3D tomosynthesis; digital radiology suite; multi-purpose ultrasound/Doppler system; DXA scanner; 12-lead ECG; cardiac stress test (ergometry); echocardiography; 24-hour Holter ECG; ambulatory BP monitor; spirometry; ambulatory polysomnographic EEG; ENT video endoscopy system; rhinomanometry system; digital orthopantomogram (OPG); PACS/RIS digital archiving system.\n\nLabs & Advanced Testing \u2014 Physical In\u2026","External Medical Partnership?":"Research-driven, no delivery partners: Clinique La Prairie is largely self-contained clinically but collaborates with nearby Swiss research institutions for scientific development and programme validation.\nKey partners include Lausanne University Hospital, Biop\u00f4le SA, University of Lausanne, \u00c9cole P\u2026","Rooms":"38","Host Hotel Rooms":"\u2014","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Programme-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"Centred on SEEDS, a medically integrated, plant-forward anti-inflammatory restaurant with programme-specific set menus (Longevity, Master Detox, Healthy Weight) assigned per guest rather than \u00e0 la carte, complemented by a Lobby Bar and Caf\u00e9 Spa offering herbal infusions, light snacks and hydration s\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"55","Total Specialist Count":null,"Specialist Staff Details":"\"A Medical Center with over 55 doctors and 25 specialties\"\n\nhttps://www.cliniquelaprairiemedical.com/en/medical-check-up/\n\nOther source says 350 total but this includes everyone beyond the core wellness/clinical team, so wouldn't be comparable to embedded concepts if we're talking just about the wellness/longevity facility","External Doctors":null,"Specialists / 10,000 sq ft":"0","Build Typology":"Purpose-built clinic","Indicative Capex Intensity":"Purpose-built medical longevity campus with hospital-grade imaging (MRI, CT, DXA), on-site laboratories, surgical theatres and high-acuity regenerative infrastructure \u2014 representing a materially higher capex intensity than hotel-embedded wellness models due to full diagnostic and interventional capa\u2026","Perceieved Capital Intensity Level (1-3)":"3","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"8","Programme Detail":"1. Revitalisation \u2014 7 days / 6 nights \u2014 from ~$37.7k\n2. Master Detox \u2014 7 days / 6 nights \u2014 from ~$24.5k\n3. Detox Reset \u2014 5 days / 4 nights \u2014 from ~$14.5k\n4. Healthy Weight \u2014 7 or 14 days / 6\u201313 nights \u2014 from ~$25.2k (14-day from ~$47.7k)\n5. Brain Health \u2014 7 days / 6 nights \u2014 from ~$34.8k\n6. Advanced Aesthetic Beauty \u2014 5 days / 4 nights \u2014 from ~$24.2k\n7. Beauty Stem Cells \u2014 4 days / 3 nights \u2014 from ~$62.5k\n8. Health Diagnostic \u2014 3 days / 2 nights \u2014 from ~$25.4k","Minimum Programme Duration (Days)":"2","Maximum Programme Duration (Days)":"14","Minimum Programme Price ($)":"14535","Maximum Programme Price ($)":"62530","No. of \u00c0 la Carte Treatments":"70","Minimum Treatment Price ($)":"390","Maximum Treatment Price ($)":null,"Treatment Details":"70+ \u00e0 la carte services (marketed as one of five programme categories), spanning 50+ spa therapies and 22 medical departments; pricing largely undisclosed, with confirmed consultations from ~CHF 350 (\u2248 $390) and programme pricing from CHF 5,900\u201350,250 (\u2248 $6,500\u201355,500).","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"0","Membership Detail":"Only have membership at their Longevity Hubs, their clinics are purely programme-led.","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"1","Product/Retail Detail":"Product offering centres on its proprietary Holistic Health longevity supplements range (including Age-Defy, Balance, Purity, Energy and Epinome\u2122), sold on-site and via global premium retail partners,\u2026","Room Rate Integration? (0/1)":null,"Room-Rate Integration Detail":null,"Other Fees":"1. Stem Cells add-on (from ~CHF 5,900 / ~$6\u20137k) \u2013 programme supplement; room not included.\n2. Municipal visitor tax (CHF 7 pppn) \u2013 external to programme pricing.\n3. Room category upgrades \u2013 supplement\u2026","What does this brand prove about scale?":"A small-key flagship can still lead globally if the clinical platform is deep and premium.","What does it prove about room-to-wellness ratios?":"Very high clinical density; rooms support the programme rather than drive the business.","What does it prove about diversification logic?":"Uses the flagship to build authority, then monetises brand trust through lighter hubs.","Notes / Observations":"Flagship benchmark: small key count, very high clinical density, and enough authority to support lighter downstream hubs."},{"Brand / Expression":"Longevity Hub by Clinique La Prairie","Operator / Hosted Within":"One&Only One Za'abeel","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Dubai, UAE","Core Positioning":"Medical Longevity","Target Segments":"UHNW, HNW, High Performance / Biohacker, Affluent Wellness","Price Tier (1-5)":"4","Est":"2024","Description":"Three-floor embedded longevity/wellness facility operated by Clinique La Prairie inside One&Only One Za\u2019abeel, offering science-backed longevity assessments (proprietary Longevity Index), wellness/wellbeing therapies, aesthetic procedures, and technology-driven treatments across 29 treatment rooms; the fifth CLP Longevity Hub globally.","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Family / Multi-Gen, Opportunistic Hotel Guest, Corporate, High Performance, Medical Recovery, Individual Wellness","Clinical Grade (1\u20135)":"4","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"334800","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"41000","Clinical & Treatment Rooms":"29","Clinical & Treatment Rooms Detail":"Longevity / High-Tech & Diagnostic \u2014 6\n(1 cryotherapy chamber; 1 far infrared therapy room; 1 neuro-wave stimulation room; 1 IV infusion room; 1 Longevity Index diagnostic suite; 1 Senaptec sensory assessment room)\n\nAesthetic / Clinical Procedure Rooms \u2014 6\n(2 injectable/consultation rooms; 2 laser treatment rooms; 2 device-based aesthetic rooms for RF microneedling, ultrasound, Indiba, body contou\u2026","No. of Specialist Facilities":"23","Specialist Facilities/Equipment":"Diagnostics & Imaging (5)\nLongevity Index AI-driven diagnostic suite; VISIA skin analysis system; bioelectrical impedance body composition analyser; non-invasive vitamin & heavy metal spectrophotometric scanner; continuous glucose monitoring (CGM) platform.\n\nLabs & Advanced Testing \u2014 Physical Infrastructure (1)\nOn-site PRP centrifuge (blood draw and platelet-rich plasma preparation confirmed; broader laboratory processing not publicly specified).\n\nRegenerative / Cell Therapy Infrastructure (2)\nS\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"229","Branded Residences":"94","Total Feeder Units":"38","External Feeder Units":"396","Wellness Area per Key":"1078.947368","Revenue Drivers":"Treatment-led, Membership-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s), Integrated","F&B Detail":"Limited in scope versus Montreux \u2014 centred on the on-site Longevity Bar (functional juices, smoothies and light wellness snacks), with no published menu or pricing; full anti-inflammatory dining is only included within the City Wellness Retreat (4-day programme), while annual members receive F&B dis\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"2","Total Specialist Count":"26","Specialist Staff Details":"9 medical practitioners (including a dermatologist and GP as the doctors, plus a physiotherapist and longevity coach), 12 wellbeing practitioners, 5 movement specialists","External Doctors":null,"Specialists / 10,000 sq ft":"6.341463415","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"Hotel-embedded urban longevity clinic with advanced diagnostics, regenerative suites and device-led optimisation infrastructure, but no imaging, laboratory or surgical capability \u2014 representing moderate capex intensity focused on treatment rooms, specialist equipment and aesthetic/biotech fit-out ra\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Treatment","Offering Type Secondary":"Membership","No. of Programmes":"1","Programme Detail":"1. City Wellness Retreat \u2013\u00a04 days / 3 nights \u2014 No price listed\n\nThree 'signature experiences' (details derived by email):\n1. Energize \u2014 210 mins (3h 30m) \u2014 AED 3,200 (~$870)\n45-min Longevity Index + 15-min cryotherapy + 60-min revitalization massage + 45-min Emsculpt (1 area) + 45-min energising IV drip.\n\u2192 Metabolic and performance optimisation.\n\n2. Rebalance \u2014 225 mins (3h 45m) \u2014 AED 3,200 (~$870)\n45-min Longevity Index + 45-min far infrared + 60-min detox massage + 30-min X-Wave (1 area) + 45-\u2026","Minimum Programme Duration (Days)":"4","Maximum Programme Duration (Days)":"4","Minimum Programme Price ($)":null,"Maximum Programme Price ($)":null,"No. of \u00c0 la Carte Treatments":"26","Minimum Treatment Price ($)":"300","Maximum Treatment Price ($)":"870","Treatment Details":"Three 'signature experiences' (details derived by email):\n1. Energize \u2014 210 mins (3h 30m) \u2014 AED 3,200 (~$870)\n45-min Longevity Index + 15-min cryotherapy + 60-min revitalization massage + 45-min Emsculpt (1 area) + 45-min energising IV drip.\n\u2192 Metabolic and performance optimisation.\n\n2. Rebalance \u2014 225 mins (3h 45m) \u2014 AED 3,200 (~$870)\n45-min Longevity Index + 45-min far infrared + 60-min detox massage + 30-min X-Wave (1 area) + 45-min detox IV drip.\n\u2192 Detox and systemic reset.\n\n3. Glow \u2014 225 mi\u2026","No. of Membership Tiers":"2","Loyalty Scheme? (0/1)":"0","Membership Detail":"1. Privilege (12 months \u2013 ~$12.2k)\nMaintenance tier with 2 annual assessments + quarterly nutrition oversight and monthly tech, massage, and movement sessions.\n\u2192 Structured, recurring longevity management model.\n\n2. Premium (3 / 6 / 12 months \u2013 ~$9.5k / $16k / $26.9k)\nHigh-frequency tier with the same diagnostic base but weekly tech, massage, and movement sessions (+ weekly cryo; supplements on 12-month).\n\u2192 Intensive optimisation and highest LTV tier.\n\nDiscovery (1 month trial)\nDiagnostic-led, o\u2026","Joining Fee":null,"Minimum Membership Price ($ per month)":"794","Maximum Membership Price ($ per month)":"2247","Product/Retail? (0/1)":"1","Product/Retail Detail":"Longevity Hub Dubai retails (1) La Prairie (not directly owned by CLP) skincare products (e.g. Skin Caviar, Platinum Rare, Life Matrix) via an on-site boutique integrated with facial treatments, (2) C\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Integration occurs primarily at suite level (including a complementary Longevity Index assessment) and through curated hotel packages:\n\n1. Za\u2019abeel & Grand Za\u2019abeel Rooms: No Longevity treatments included (Movement Studio access only).\n2. Za\u2019abeel Suite, Urban Suite, Creative Suite, Skyline Signatur\u2026","Other Fees":"1. 10% service charge + 5% VAT (wellbeing); 5% VAT (aesthetics).\n2. 3.95% Amex surcharge.\n3. 50% deposit (external guests) + 24h 100% cancellation policy.\n4. Consultation-gated pricing (medical & long\u2026","What does this brand prove about scale?":"Shows CLP can extend from mothership to hotel-embedded hubs without recreating the full campus.","What does it prove about room-to-wellness ratios?":"Substantial for a hotel, but wellness remains nested inside a larger hospitality asset.","What does it prove about diversification logic?":"Partnership + membership model adds recurring revenue while avoiding full destination-clinic capex.","Notes / Observations":"Hotel-embedded CLP extension with real wellness scale, but more treatment- and membership-led than the Montreux flagship."},{"Brand / Expression":"Chenot Palace Weggis","Operator / Hosted Within":"Chenot Group","Level / Category":"A \u2014 Mothership","Status":"Established","Location City, Country":"Lucerne, Switzerland","Core Positioning":"Medical Longevity","Target Segments":"UHNW, HNW, Medical Tourism","Price Tier (1-5)":"5","Est":"2020","Description":"Chenot Palace Weggis is an ultra-luxury medical wellness retreat/resort on Lake Lucerne built around the science-driven Chenot Method, offering highly structured 7-night+ detox and longevity programmes within a refined hotel setting. Combining Western diagnostics with Traditional Chinese Medicine principles, controlled fasting-mimicking nutrition, hydrotherapy, hypoxia, cryotherapy and daily medic\u2026","Does the hotel have a separate spa? (0/1)":"\u2014","Target Audiences":"Individual Wellness, High Performance, Medical Recovery","Clinical Grade (1\u20135)":"4","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"187539.61","Total GFA (sq ft)":"208572.292","Stated Wellness/Clinical Area (sq ft)":"53819.55","Clinical & Treatment Rooms":"97","Clinical & Treatment Rooms Detail":"Medical & Diagnostic\n(Doctor consultation rooms; functional diagnostic rooms for metabolic testing, oxidative stress, arterial stiffness and bio-energetic assessment; lab sampling room; IV therapy rooms; ozone therapy rooms; colon hydrotherapy rooms; acupuncture rooms)\n\nHydrotherapy\n(Hydro-aromatherapy bath rooms; hydro-jet treatment rooms; phyto-mud wrap rooms)\n\nEnergetic / Bodywork Treatment Roo\u2026","No. of Specialist Facilities":"46","Specialist Facilities/Equipment":"Diagnostics & Imaging (11)\nDXA bone densitometry scanner; digital infrared thermal imaging (DITI); arterial stiffness / pulse wave analysis device; AGEs measurement device; minerals & heavy metals analyser; skin collagen ultrasound; body composition analyser; oxidative stress assessment device; bio-energetic resonance analysis system; 3D body scanner; facial diagnostic scanner.\n\nLabs & Advanced Testing \u2014 Physical Infrastructure (2)\nOn-site clinical laboratory (blood, urine, saliva biomarker proc\u2026","External Medical Partnership?":"No","Rooms":"97","Host Hotel Rooms":"\u2014","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Programme-led, Room-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"Operates a fully integrated, medically prescribed F&B model built around the mandatory Chenot Diet\u00ae \u2014 an ~850 kcal/day plant-based fasting-mimicking protocol embedded within every programme. All meals are served exclusively to in-house guests in a single lake-facing Dining Room, with a secondary tea\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"6","Total Specialist Count":"100","Specialist Staff Details":"Chenot Palace Weggis cites 100+ specialist staff, covering the full clinical and treatment ecosystem. This includes 6 confirmed on-site doctors, supported by nurses and lab technicians within the Medical Department, alongside approximately 50 spa/therapy practitioners delivering the Chenot Method, plus medical aesthetics and human performance specialists. The 100 figure reflects the total treatmen\u2026","External Doctors":null,"Specialists / 10,000 sq ft":"18.58060872","Build Typology":"Retrofitted resort","Indicative Capex Intensity":"High capex hybrid redevelopment: Conversion of a historic luxury resort into a medically licensed wellness clinic, including a newly built ~5,000 sqm medical spa annex with advanced diagnostics, clinical treatment infrastructure, cryotherapy, altitude training, IV therapy and specialist equipment. S\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"5","Programme Detail":"1. Advanced Detox \u2014 7 days / 6 nights \u2014 from ~$9.4k total stay\n(Programme ~$6.2k + entry room ~$3.2k)\n2. Recover & Energise \u2014 7 days / 6 nights \u2014 from ~$10.4k total stay\n(Programme ~$7.2k + entry room ~$3.2k)\n3. Prevention & Ageing Well \u2014 7 days / 6 nights \u2014 from ~$11.2k total stay\n(Programme ~$8.0k + entry room ~$3.2k)\n4. Recover & Energise with Sleep Cycles \u2014 7 days / 6 nights \u2014 from ~$12.1k total stay\n(Programme ~$8.9k + entry room ~$3.2k)\n5. Body Insights & Optimisation \u2014 5 days / 4 nights \u2014\u2026","Minimum Programme Duration (Days)":"5","Maximum Programme Duration (Days)":"7","Minimum Programme Price ($)":"6200","Maximum Programme Price ($)":"8900","No. of \u00c0 la Carte Treatments":"67","Minimum Treatment Price ($)":"Not published","Maximum Treatment Price ($)":"Not published","Treatment Details":"Chenot Palace Weggis offers 67 listed \u00e0 la carte treatments across six departments, with the largest weighting in medical aesthetics (17) and core medical diagnostics/treatments (16), reinforcing its positioning as a medically supervised detox and longevity clinic rather than a conventional spa. Human performance (12) and Chenot Method manual aesthetics (11) support the detox foundation, while hydrotherapy (3) functions as the programme spine. Notably, no individual treatment prices are publishe\u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"1","Membership Detail":"Chenot does not operate a paid membership structure, but it does run a three-tier, frequency-based loyalty scheme called the Chenot Loyalty Club (CLC). Status is awarded annually based on the number of stays in the previous calendar year (valid 1 January\u201331 December), applies only at Weggis, is strictly personal and non-transferable, and offers percentage discounts rather than points accumulation.\n\nThree Tiers\n1. Chenot Loyal (1 stay/year): 10% off programmes + 10% off Spa & Medical treatments* \u2026","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"1","Product/Retail Detail":"Retail is structured as a proprietary extension of the Chenot Method\u00ae rather than a standalone merchandising play, comprising ~25\u201328 in-house SKUs across four categories: the 2024 relaunched senolytic\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Programmes and rooms are priced entirely separately: guests pay a fixed per-person programme fee and add a per-night room rate, with both itemised independently. There is no bundled or all-inclusive pricing, allowing flexible room upgrades, dual-programme stays for couples, and straightforward exten\u2026","Other Fees":"1. \u00c0 la carte treatments, medical aesthetics & lab tests \u2014 priced separately, prescribed during stay, charged on final invoice (no published rates).\n2. 100% prepayment required \u2014 full stay cost due at\u2026","What does this brand prove about scale?":"A single flagship can scale brand influence when method, retention and outcomes are strong.","What does it prove about room-to-wellness ratios?":"Wellness is core, not ancillary: spa/clinical space is large relative to the room base.","What does it prove about diversification logic?":"Still chiefly stay-led; scale comes from method depth, not broad format diversification.","Notes / Observations":"Method-led flagship with closely matched room and wellness capacity; brand power comes from protocol depth, not format spread."},{"Brand / Expression":"Chenot Espace","Operator / Hosted Within":"One&Only Portonovi","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Herceg Novi, Montenegro","Core Positioning":"Detox Clinic","Target Segments":"HNW, UHNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2021","Description":"Chenot Espace at One&Only Portonovi is a 4,000 m\u00b2 medical wellness spa within the luxury Adriatic resort, created through an exclusive partnership between Chenot and One&Only. Built around the Chenot Method\u00ae, it combines Traditional Chinese Medicine principles with advanced diagnostics (Chenot Lifestyle Biomarkers\u00ae) to personalise 2\u20137 night detox, stress and fitness programmes. Clinically led yet \u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Opportunistic Hotel Guest, High Performance","Clinical Grade (1\u20135)":"3","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"2614000","Total GFA (sq ft)":"376700","Stated Wellness/Clinical Area (sq ft)":"43000","Clinical & Treatment Rooms":"28","Clinical & Treatment Rooms Detail":"Departments served (7 total):\n1. Medical \u2014 consultation rooms, diagnostics, IV therapy, ozone, hydro-colon\n2. Human Performance \u2014 fitness testing, neuromuscular activation, movement assessments\n3. Hydrotherapy \u2014 hydro-aromatherapy, phyto-mud, hydro-jet rooms\n4. Aesthetic \u2014 body and facial treatment rooms\n5. Medical Aesthetic \u2014 device-based and regenerative treatments\n6. Traditional Aesthetic \u2014 wra\u2026","No. of Specialist Facilities":"22","Specialist Facilities/Equipment":"Diagnostics & Imaging (9)\nArterial stiffness / pulse wave analysis device; oxidative stress assessment system; AGE reader (glycation scanner); skin collagen ultrasound; minerals & heavy metals spectrophotometer; Tanita body composition analyser; HRV stress test system with biofeedback; bio-energetic resonance analysis system; resting metabolic rate analyser (indirect calorimetry).\n\nLabs & Advanced Testing \u2014 Physical Infrastructure (1)\nLaboratory diagnostic capability (blood & urine sample collec\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"123","Branded Residences":"10","Total Feeder Units":"104","External Feeder Units":"208","Wellness Area per Key":"413.4615385","Revenue Drivers":"Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"F&B is clinically integrated through the mandatory Chenot Diet\u00ae (~850 kcal/day plant-based fasting-mimicking protocol), with a lighter ~1,200 kcal Biolight option. The diet is bundled into all residential programmes and supported by nutritional consultations, positioned as a metabolic intervention r\u2026","Medical Licensing Model":"Light-touch medical","On-Site Doctors":"2","Total Specialist Count":null,"Specialist Staff Details":"Total practitioner headcount is not publicly disclosed, which is why the full count remains blank. \nWhat is confirmed is 2 on-site doctors (1 medical doctor in internal medicine/cardiology and 1 TCM/integrative doctor), supported by nursing (IV/ozone), physiotherapy, and a spa management team. The programme structure also requires on-site nutritionists, spa/body therapists, medical aesthetic techn\u2026","External Doctors":null,"Specialists / 10,000 sq ft":"0","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"Moderate-to-high capex resort integration: Purpose-built ~4,000 sqm medical wellness spa embedded within a new-build ultra-luxury resort, incorporating structured diagnostics, IV and ozone therapy, cryotherapy, hydrotherapy infrastructure and specialist treatment rooms. Capital intensity sits above \u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"7","Programme Detail":"1. Advanced Detox \u2014 6 days / 7 nights \u2014 from ~$4.6k\nFlagship metabolic reset; full biomarker diagnostics, daily hydrotherapy circuit (phyto-mud, hydro-jet, hydro-aromatherapy), energetic massages and bio-energetic treatments under medical supervision.\n\n2. De-Stress & Re-Charge \u2014 4 days / 5 nights \u2014 from ~$3.7k\nNervous-system recalibration and fatigue recovery; HRV testing, photo-biomodulation, neuro-acoustic relaxation, hydrotherapy and structured massage protocol.\n\n3. Cleanse & Rebalance \u2014 3 da\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"6","Minimum Programme Price ($)":"2400","Maximum Programme Price ($)":"4600","No. of \u00c0 la Carte Treatments":"60","Minimum Treatment Price ($)":"33","Maximum Treatment Price ($)":"352","Treatment Details":"The 60+ treatment portfolio blends medical diagnostics, regenerative therapies, performance science and luxury spa modalities in a resort-adapted medical wellness format.\n\nMedical & Diagnostics: Doctor consultations, biomarker testing (vascular age, oxidative stress, AGEs, heavy metals), lab testing, HRV stress testing, metabolic rate analysis.\nClinical Therapies: IV nutrient infusions, systemic ozone therapy, hydro-colon therapy, acupuncture, bio-energetic treatments.\nPerformance & Longevity Te\u2026","No. of Membership Tiers":"2","Loyalty Scheme? (0/1)":"0","Membership Detail":"Seasonal gym-led membership providing fitness and wet-area access, with the Privilege tier adding body composition analysis and a personalised nutrition consultation, but no clinical diagnostics or structured longevity programming.\n\n1. 1-Month Membership (~$400 / \u20ac370): Unlimited gym access; indoor pool access; wet facilities (sauna, steam room, hammam); 20% spa treatment benefit.\n2. 1-Month Privilege Membership (~$2,600 / \u20ac2,400): Unlimited gym access; indoor pool access; wet facilities (sauna,\u2026","Joining Fee":null,"Minimum Membership Price ($ per month)":"400","Maximum Membership Price ($ per month)":"2600","Product/Retail? (0/1)":"1","Product/Retail Detail":"Retail model mirrors that of Chenot Palace Weggis almost exactly, functioning as a brand-controlled extension of the Chenot Method\u00ae rather than a property-specific merchandising concept. The full Chen\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"accommodation and Chenot programmes operate on a deliberately unbundled model. The room rate includes only core resort access (pools, gym, sauna/steam, beach, breakfast), while all Chenot programmes, diagnostics, treatments and retail are priced separately and subject to a 10% service charge. The Ch\u2026","Other Fees":"1. Day passes from \u20ac130\u2013\u20ac190 (non-resident access)\n2. 10% mandatory service charge on all Chenot programmes and treatments \n3. Optional medical upsells (labs, IV therapy, ozone, hydro-colon, cryothera\u2026","What does this brand prove about scale?":"Shows Chenot can export its method via resort partnerships without building a second mothership.","What does it prove about room-to-wellness ratios?":"Meaningful resort wellness density, but still lighter than a true standalone clinic.","What does it prove about diversification logic?":"Asset-light brand extension: Chenot provides method; One&Only provides rooms and destination.","Notes / Observations":"Lighter Chenot resort translation with real wellness scale, but still reliant on One&Only's destination platform."},{"Brand / Expression":"SHA Wellness Clinic, Spain","Operator / Hosted Within":"AB Living Group","Level / Category":"A \u2014 Mothership","Status":"Established","Location City, Country":"Alicante, Spain","Core Positioning":"Medical Longevity","Target Segments":"HNW, Medical Tourism, UHNW, High Performance / Biohacker","Price Tier (1-5)":"4","Est":"2008","Description":"Founded in October 2008 by Alfredo Bataller Parietti, SHA Wellness Clinic is the flagship of AB Living Group \u2014 a 93-suite, 11-residence dedicated wellness clinic on the Mediterranean coast near Altea. The SHA Method integrates Western preventive medicine, regenerative therapies, and Eastern natural therapies (TCM, acupuncture, macrobiotic nutrition) across 50+ medical and holistic specialties. Nam\u2026","Does the hotel have a separate spa? (0/1)":"\u2014","Target Audiences":null,"Clinical Grade (1\u20135)":"4","Residential (0/1)":"1","Hotel Guest (0/1)":"0","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"645834.63","Total GFA (sq ft)":"290625.58","Stated Wellness/Clinical Area (sq ft)":"86111.28","Clinical & Treatment Rooms":"90","Clinical & Treatment Rooms Detail":"SHA Spain operates a 90-room integrated medical and wellness clinic structured across four thematic treatment zones \u2014 Western medicine, Eastern medicine, hydrotherapy and bioenergetics \u2014 supported by 13+ specialist clinical departments. The facility combines consultation suites, regenerative procedure rooms, multi-station infusion areas, diagnostic labs and high-tech longevity rooms (HBOT, cryothe\u2026","No. of Specialist Facilities":"54","Specialist Facilities/Equipment":"Diagnostics & Imaging (14)\nAdvanced Preventive Diagnostic Circuit; digital infrared photoplethysmography; AGE reader (glycation scanner); segmental body composition analyser; 3D body scanner; facial & hair diagnostic scanner; full-body densitometer (DEXA); ultrasound (multi-organ); Doppler ultrasound; Holter BP monitor; night polygraph (sleep study); dental digital imaging/visiograph; CAD-CAM digital smile design system; electromagnetic field mapping device.\n\nLabs & Advanced Testing \u2014 Physical I\u2026","External Medical Partnership?":"No","Rooms":"93","Host Hotel Rooms":"\u2014","Branded Residences":"11","Total Feeder Units":"0","External Feeder Units":"596","Wellness Area per Key":null,"Revenue Drivers":"Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"SHAmadi Restaurant \u2014 dedicated macrobiotic-inspired wellness restaurant with three medically prescribed menus: SHA (gourmet, ~1,500 kcal/day, 3-course with seafood), Biolight (lighter, active detox) and Kushi (strictest, oil-free, flour-free, ~1,000 kcal/day). All menus exclude meat, refined sugar, \u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"30","Total Specialist Count":"350","Specialist Staff Details":"SHA\u2019s most defensible first-party figure is 350 specialist practitioners at SHA Spain (15th anniversary press release, October 2023), at which time Spain was the only operational property. This total encompasses the full multidisciplinary team across 50+ medical and wellness specialties. The frequently cited figure of 30+ full-time doctors refers specifically to on-site physicians and sits within \u2026","External Doctors":null,"Specialists / 10,000 sq ft":"40.64508157","Build Typology":"Purpose-built clinic","Indicative Capex Intensity":"Purpose-built 27,000 m\u00b2 campus with 7 interconnected buildings, 8,000 m\u00b2 clinic with advanced diagnostic and regenerative infrastructure (cryotherapy, hyperbaric, photobiomodulation, ozone, IHT, neuromodulation), hydrotherapy circuit, heliport, cinema, organic garden and 11 private-pool residences \u2014\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"9","Programme Detail":"1. Stay Your Way \u2014 3\u20137+ nights \u2014 from ~\u20ac2,895 (3 nights) to ~\u20ac6,755 (7 nights)\nFlexible, build-your-own framework; core diagnostics, medical consult, personalised nutrition and hydrotherapy access, with treatments added \u00e0 la carte.\n(From \u20ac965 per guest/night.)\n\n2. Detox & Optimal Weight \u2014 7\u201314 nights \u2014 from ~\u20ac7,105 (7 nights) to ~\u20ac14,210 (14 nights)\nStructured metabolic reset; advanced diagnostics, body composition tracking and medically supervised detox therapies.\n(From \u20ac1,015 per guest/night.)\u2026","Minimum Programme Duration (Days)":"3","Maximum Programme Duration (Days)":"14","Minimum Programme Price ($)":"3130","Maximum Programme Price ($)":"23660","No. of \u00c0 la Carte Treatments":"210","Minimum Treatment Price ($)":"43","Maximum Treatment Price ($)":"9600","Treatment Details":"SHA Spain offers 210+ individually priced \u00e0 la carte treatments across medical diagnostics, genomic and longevity testing, IV and regenerative medicine (including stem-cell and plasma-based procedures), sexual health, cognitive therapies, advanced aesthetics, holistic medicine, psychology and physical performance.\n\nThe menu spans from basic laboratory tests (~$43) to high-ticket regenerative procedures (~$9,600), reflecting a fully integrated, physician-led medical longevity model rather than a \u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"1","Membership Detail":"No memberships, but do have SHA Privileged, a spend-based loyalty programme (not a paid membership). Guests are automatically enrolled after their first stay, earn 1 point per \u20ac10 spent, and unlock tiered benefits based on cumulative spend. There is no joining fee or annual cost, and access remains tied to booking a stay.\n\n1. Ruby \u2013 5% boutique & wellness discount (excl. clinic, aesthetics, genetics).\n2. Emerald (~\u20ac35k+ spend) \u2013 10% discounts; late check-out; laundry benefit.\n3. Diamond (~\u20ac75k+ \u2026","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"1","Product/Retail Detail":"SHA Wellness Clinic operates the SHA Boutique, selling ~340 total products, of which ~35\u201337 SKUs are proprietary SHA-branded items. The remainder are curated third-party premium wellness and skincare \u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Accommodation priced separately from programmes but integrated:\n\n1. Programme pricing excludes accommodation \u2014 guests select suite independently.\n2. All programmes include full-board macrobiotic nutrition (3 meals/day + medicinal teas).\n3. Non-programme stays: mandatory full-board (\u20ac175/person/day).\u2026","Other Fees":"1. Full-board meal plan (non-programme): \u20ac175/person/day.\n2. Nutrition consultation: \u20ac160; validation (returning guests): \u20ac80.\n3. 30% deposit to confirm; balance at check-in.\n4. Prescribed supplements\u2026","What does this brand prove about scale?":"Proves a clinic-led mothership can scale into a global platform when hospitality and medicine are both strong.","What does it prove about room-to-wellness ratios?":"A strongly wellness-weighted campus: clinical space and programmes clearly outrank pure room economics.","What does it prove about diversification logic?":"Combines stays, treatments and residences; broader than clinic-only or hotel-spa models.","Notes / Observations":"Clinic-led wellness campus benchmark: deep medical infrastructure and residential logic create platform-level defensibility."},{"Brand / Expression":"SHA Emirates, Al Jurf (UAE)","Operator / Hosted Within":"IMKAN / AB Living Group","Level / Category":"A \u2014 Mothership","Status":"Pipeline","Location City, Country":"Abu Dhabi, UAE","Core Positioning":"Medical Longevity","Target Segments":"UHNW, HNW, Medical Tourism","Price Tier (1-5)":"5","Est":"2026-07-01 00:00:00","Description":"SHA Wellness Clinic Emirates is the brand\u2019s Middle East outpost: a purpose-built 12.5-hectare \u201chealthy living island\u201d at AlJurf developed in partnership with IMKAN, combining a ~120-suite health resort, 110+ treatment rooms delivering the full SHA Method, and 137 branded residences within a masterplanned wellness ecosystem. Unlike a satellite spa or embedded concept, it is a fully integrated desti\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Family / Multi-Gen, High Performance","Clinical Grade (1\u20135)":"4","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"1345488.8","Total GFA (sq ft)":"Undisclosed","Stated Wellness/Clinical Area (sq ft)":"Undisclosed","Clinical & Treatment Rooms":"110","Clinical & Treatment Rooms Detail":"Full SHA Wellness Clinic with 110 treatment rooms (announced by Alejandro Bataller, Spa Business 2024). Expected to replicate SHA Spain's clinical offering across:\n\nMedical consultation rooms (preventive/anti-ageing, regenerative, aesthetic, internal medicine, genomic medicine, nutrition, psychology, cognitive stimulation)\n\nHolistic therapy rooms (acupuncture, osteopathy, shiatsu, reflexology, rei\u2026","No. of Specialist Facilities":"Not yet published","Specialist Facilities/Equipment":"Not yet published","External Medical Partnership?":"No","Rooms":"120","Host Hotel Rooms":"\u2014","Branded Residences":"159","Total Feeder Units":"67","External Feeder Units":"284","Wellness Area per Key":null,"Revenue Drivers":"Residences, Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"At SHA Wellness Clinic Emirates, nutrition remains a medically prescribed core pillar, delivered on a full-board basis with guests assigned one of the same three macrobiotic-inspired menus as the Spain flagship (SHA, Biolight or Kushi) following consultation, with predominantly plant-based cuisine a\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"Undisclosed","Total Specialist Count":"Undisclosed","Specialist Staff Details":"Not yet disclosed (under construction). SHA's official materials state that residents and guests will have access to \"expert professionals, renowned doctors, therapists, personal trainers, yoga & meditation instructors, healthy-cooking chefs, all available around the clock.\"\n\nExpected to replicate SHA Spain's multi-disciplinary model with specialists in: preventive & anti-ageing medicine, regenera\u2026","External Doctors":null,"Specialists / 10,000 sq ft":null,"Build Typology":"Purpose-built clinic","Indicative Capex Intensity":"AED 600 million (~US$163 million) total investment for the SHA wellness clinic, health resort and island infrastructure. Broader AlJurf master plan valued at AED 15 billion. Purpose-built private island with 120 suites, 110 treatment rooms, 137 residences, multiple pavilions, marina, beach club, sus\u2026","Perceieved Capital Intensity Level (1-3)":"3","Offering Type Primary":"Programme","Offering Type Secondary":"Residential","No. of Programmes":"TBC","Programme Detail":"Expected to mirror Spain as it's a full-spec clinic rather than a secondary expression","Minimum Programme Duration (Days)":null,"Maximum Programme Duration (Days)":null,"Minimum Programme Price ($)":null,"Maximum Programme Price ($)":null,"No. of \u00c0 la Carte Treatments":"TBC","Minimum Treatment Price ($)":null,"Maximum Treatment Price ($)":null,"Treatment Details":"Expected to mirror Spain as it's a full-spec clinic rather than a secondary expression","No. of Membership Tiers":"1","Loyalty Scheme? (0/1)":"1","Membership Detail":"\"SHA Residences Owners Club \u2014 exclusive to residence purchasers. Benefits include:\n\n\u2022 Unprecedented access to SHA Wellness Clinic (24/7 on-call doctors, therapists, trainers, chefs)\n\u2022 In-residence medical and clinical treatments\n\u2022 SHA Privileged programme (details TBC)\n\u2022 Residence exchange modality between SHA properties (Spain, Mexico, Emirates)\n\u2022 Room service from SHA restaurants, private chef/cooking services\n\u2022 Access to all island pavilions, marina, beach club, gym, infinity pool, kids pool,\u2026","Joining Fee":"Via property purchase (from AED 4.6M)","Minimum Membership Price ($ per month)":"N/A (included with residence)","Maximum Membership Price ($ per month)":"N/A (included with residence)","Product/Retail? (0/1)":"1","Product/Retail Detail":"Expected to replicate the SHA retail concept at Emirates with on-site boutique and personalised supplement prescriptions. Residential owners likely to receive product deliveries as part of SHA service\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Details not yet published for SHA Emirates (under construction). Expected model based on SHA Spain:\n\n1. Programme pricing separate from accommodation \u2014 guests select suite independently.\n2. All programmes include full-board macrobiotic nutrition.\n3. Non-programme stays: mandatory full-board meal sup\u2026","Other Fees":"1. Residential purchase: 70/30 payment plan (70% during construction, 30% on handover).\n2. Service charges / community fees: not yet disclosed.\n3. Expected programme supplements, nutrition consultatio\u2026","What does this brand prove about scale?":"Proves SHA can scale from clinic to full wellness ecosystem, including real estate.","What does it prove about room-to-wellness ratios?":"Designed at community scale: treatment capacity and residences materially exceed a normal resort model.","What does it prove about diversification logic?":"Wellness becomes both operating business and residential product, not just a stay experience.","Notes / Observations":"Turns SHA into a wellness-plus-real-estate ecosystem; execution risk remains, but monetisation clearly moves beyond stays."},{"Brand / Expression":"Lanserhof Lans (Austria)","Operator / Hosted Within":"Lanserhof Group","Level / Category":"A \u2014 Mothership","Status":"Established","Location City, Country":"Tyrol, Austria","Core Positioning":"Medical Longevity","Target Segments":"HNW, Medical Tourism, UHNW","Price Tier (1-5)":"4","Est":"1984","Description":"Lanserhof Lans is the original flagship of the Lanserhof Group, situated on an Alpine high plateau in Lans near Innsbruck, Tyrol, Austria. Opened as a hotel in 1974 and transformed into a Mayr-method medical spa in 1984, it was acquired and repositioned by the current Lanserhof team (Dr Christian Harisch, KR Anton Pletzer) in 1998. A major renovation and expansion by architect Christoph Ingenhoven\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Medical Recovery, High Performance","Clinical Grade (1\u20135)":"4","Residential (0/1)":"0","Hotel Guest (0/1)":"1","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"107639.1","Total GFA (sq ft)":"63054.987","Stated Wellness/Clinical Area (sq ft)":"32291.73","Clinical & Treatment Rooms":"48","Clinical & Treatment Rooms Detail":"The most defensible single estimate for the full clinical and treatment footprint at Lanserhof Lans is approximately 48 rooms/stations. Of these, 16 rooms are explicitly confirmed hands-on therapy rooms (massage/manual therapy suites referenced by booking platforms), while the remaining ~32 rooms are derived from programme infrastructure described across the official brochure and treatment invento\u2026","No. of Specialist Facilities":"38","Specialist Facilities/Equipment":"Diagnostics & Imaging (13)\nEchocardiography system; diagnostic ultrasound/sonography suite (abdomen, thyroid, carotid, prostate); colour Doppler vascular ultrasound; resting ECG; exercise ECG / ergometry; 24-hour Holter ECG monitoring; 24-hour ambulatory blood pressure monitoring; ankle\u2013brachial index (ABI) vascular assessment device; spirometry lung-function system; FibroScan liver elastography device; capsule endoscopy system; sleep laboratory / polysomnography facility; 24-hour HRV monitoring\u2026","External Medical Partnership?":"No","Rooms":"67","Host Hotel Rooms":"\u2014","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"Lanserhof Energy Cuisine \u2014 the proprietary F.X. Mayr-based nutrition programme, integral to every stay. Organic, regional and seasonal ingredients; meals follow the digestive rhythm (light supper, no raw food after 4pm). Three cuisine levels:\n\n1. Energy Cuisine Basic \u2014 included in all cures; gentle,\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"8","Total Specialist Count":"50","Specialist Staff Details":"Lanserhof Lans operates with an on-site clinical and therapy team of ~50 specialists, including approximately 5\u20138 full-time resident physicians (general medicine/F.X. Mayr, internal medicine and cardiology) supported by therapists, diagnostic staff, nutrition specialists, movement trainers and psychotherapy practitioners. In addition to this resident team, the clinic is supported by ~35 external s\u2026","External Doctors":"35","Specialists / 10,000 sq ft":"15.4838406","Build Typology":"Retrofitted resort","Indicative Capex Intensity":"2016\u201317 Ingenhoven renovation: major expansion adding 5,500 sqm new oval building (5 storeys), new bathhouse with indoor/outdoor saltwater pool, 3-room cryotherapy chamber, sauna complex, 16 additional rooms/suites, expanded medical and diagnostic facilities. Estimated investment in the tens of mill\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"10","Programme Detail":"Core detox programmes\n1. Lanserhof Cure Classic \u2014 7\u201321 nights \u2014 from ~\u20ac2.9k\u2013\u20ac6.1k\nFoundational Mayr detox and gut regeneration programme; physician consultations, therapeutic massage, detox drainage, algae pack with liver wrap, foot reflexology, Kneipp therapy and daily movement/relaxation sessions.\n\n2. Lanserhof Cure Classic Plus \u2014 7\u201321 nights \u2014 from ~\u20ac4.0k\u2013\u20ac7.2k\nExpanded Classic protocol with additional diagnostics and therapies including craniosacral therapy, energetic treatments, VO\u2082 perform\u2026","Minimum Programme Duration (Days)":"7","Maximum Programme Duration (Days)":"21","Minimum Programme Price ($)":"3200","Maximum Programme Price ($)":"8600","No. of \u00c0 la Carte Treatments":"90","Minimum Treatment Price ($)":"70","Maximum Treatment Price ($)":"2171","Treatment Details":"Extensive \u00e0 la carte treatment menu (~90+ treatments, 2022 brochure). Key categories and price ranges (EUR):\n\nDIAGNOSTICS & SPECIALIST EXAMS:\n\u2022 Internal check \u20ac1,562 / Cardiology check \u20ac1,992\n\u2022 Echocardiography \u20ac428 / Ergometry \u20ac378 / Spirometry \u20ac134 / Spiroergometry \u20ac308\n\u2022 Capsule endoscopy \u20ac1,599 / Sleep laboratory \u20ac1,166 / HRV 24h \u20ac508\n\u2022 Ultrasound (abdomen \u20ac378, thyroid \u20ac216, neck vessels \u20ac218, prostate \u20ac186)\n\u2022 Specialist exams: dermatological \u20ac236, neurological \u20ac449, urological \u20ac478, dental\u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"0","Membership Detail":"No formal membership or loyalty programme identified. Lanserhof Lans operates a pure destination medical wellness model where guests book programme-based stays (minimum 7 nights). The 68% repeat guest rate suggests strong organic loyalty without a structured programme. Lanserhof at The Arts Club in London operates separately as a private members' club wellness concept (in partnership with The Arts Club), but this is not linked to Lans as a membership benefit. No published joining fee, annual fee\u2026","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"1","Product/Retail Detail":"Lanserhof operates multiple product lines available in-house and online (shop.lanserhof.com):\n\n1. LANS Derma \u2014 certified natural skincare range developed with Lanserhof medical/dermatology team. Austr\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Programme pricing and accommodation are separate, allowing guests to choose room independently:\n\n1. Programme fee: covers medical consultations, therapies, treatments as per programme (e.g., Cure Classic 7n \u20ac2,514, Cure Advanced 14n \u20ac6,244).\n\n2. Accommodation fee: per person per night, payable along\u2026","Other Fees":"1. Mandatory daily flat rate: ~\u20ac62\u201363/night (on-call physician, Kneipp, group therapies, lectures) \u2014 generally included in cure programme pricing.\n2. Energy Cuisine upgrade (3/2 or Active level): +\u20ac49\u2026","What does this brand prove about scale?":"One disciplined flagship can anchor a wider brand if repeat rates and medical credibility are high.","What does it prove about room-to-wellness ratios?":"Compact but clinically dense: more serious than a spa resort, less sprawling than SHA.","What does it prove about diversification logic?":"Intentionally narrow: programme-led medical stays take priority over memberships or lifestyle spin-offs.","Notes / Observations":"Disciplined medical-stay benchmark: clinically credible and outcomes-led, with less lifestyle sprawl and clearer brand logic."},{"Brand / Expression":"Lanserhof at The Arts Club (London, UK)","Operator / Hosted Within":"The Arts Club Mayfair","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"London, UK","Core Positioning":"Medical Longevity","Target Segments":"UHNW, HNW, High Performance / Biohacker","Price Tier (1-5)":"4","Est":"2019","Description":"Lanserhof at The Arts Club is the world's first \"medical gym\" \u2014 a six-storey urban wellness clinic and private members' club in Mayfair, London. A joint venture between the Lanserhof Group and The Arts Club (founded 1863, co-founded by Charles Dickens), it occupies the former Dover Street Market building at 17-18 Dover Street. Designed by Christoph Ingenhoven / ingenhoven associates, the 2,000 sqm\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, High Performance, Medical Recovery, Corporate","Clinical Grade (1\u20135)":"3","Residential (0/1)":"0","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"21528","Clinical & Treatment Rooms":"14","Clinical & Treatment Rooms Detail":"Across multiple public sources, 14 distinct clinical and treatment room types can be identified at Lanserhof at The Arts Club London, though no single official figure exists for the total number of rooms. The count below therefore represents a reconstructed tally of room types rather than the exact number of individual rooms, with several categories described in the plural and therefore likely com\u2026","No. of Specialist Facilities":"24","Specialist Facilities/Equipment":"Diagnostics & Imaging (4)\nSiemens MAGNETOM Skyra 3T open-bore MRI scanner; diagnostic ultrasound / sonography system (joint, soft tissue and guided procedures); 12-lead resting ECG system; echocardiography unit for structural and functional cardiac imaging. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (1)\nOn-site phlebotomy / blood-draw station for specimen collection (laboratory analysis conducted externally via partner labs rather than an in-house wet lab). \n\nIV / Infusion Infrastructur\u2026","External Medical Partnership?":"Lanserhof at The Arts Club maintains formal fast-track referral partnerships with two major London hospital providers: HCA Healthcare UK \u2014 including The Wellington Hospital, The London Bridge Hospital, The Princess Grace Hospital, The Lister Hospital, and The Portland Hospital \u2014 as well as Cleveland\u2026","Rooms":"0","Host Hotel Rooms":"16","Branded Residences":"0","Total Feeder Units":"181","External Feeder Units":"0","Wellness Area per Key":"118.9392265","Revenue Drivers":"Membership-led, Treatment-led, Programme-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"Members' Lounge \u2014 exclusive first-floor lounge serving a light, nourishing menu inspired by Lanserhof's Mayr principles. Healthy snacks and drinks including 10 signature herbal tea blends (e.g., \"Active\" \u2014 green tea, lemon verbena, lemongrass; \"Detox\" \u2014 birch, pansy, melissa, dandelion root) and smo\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"16","Total Specialist Count":"28","Specialist Staff Details":"Based on the Lanserhof website team listing, ~16 medically qualified doctors practise at Lanserhof at The Arts Club London. These are physicians holding Dr or Professor titles across specialties including gastroenterology, general practice, cardiology, neurology/sleep medicine, radiology, orthopaedics, spine surgery, endocrinology, and sports & MSK medicine.\n\nAlongside these are ~12 additional all\u2026","External Doctors":null,"Specialists / 10,000 sq ft":"13.00631735","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"Conversion of a six-storey Mayfair townhouse/retail building (former Dover Street Market) into a medical wellness facility. Designed by Ingenhoven Architects (D\u00fcsseldorf). Includes installation of a 3T Siemens Skyra MRI scanner (typically \u00a31-2M alone), cryotherapy chamber, hyperbaric oxygen chamber,\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Membership","Offering Type Secondary":"Treatment","No. of Programmes":"4","Programme Detail":"1. LIFE \u2014 Lanserhof Integrative Fasting Experience (7/14/21 days):\nSignature medically-supervised fasting programme based on LANS Med Concept (F.X. Mayr method). Includes initial lifestyle consultation, follow-up, nurse assessments, comprehensive functional blood tests, functional gut health analysis, nutritional consultation, IV treatments, supplement supply, body composition MRI or Styku scan, abdominal treatments, fasting level adjustments, deep tissue massage, lymphatic drainage, visceral os\u2026","Minimum Programme Duration (Days)":"7","Maximum Programme Duration (Days)":"21","Minimum Programme Price ($)":"3150","Maximum Programme Price ($)":"11340","No. of \u00c0 la Carte Treatments":"70","Minimum Treatment Price ($)":"25","Maximum Treatment Price ($)":"3717","Treatment Details":"Comprehensive \u00e0 la carte treatment menu (~70+ services, 2022 price list). Key categories and prices (GBP):\n\nDIAGNOSTICS & IMAGING:\n\u2022 MRI: one part \u00a3790, two parts \u00a31,200, three \u00a31,680, four \u00a32,160, cardiac \u00a32,030, whole body \u00a32,950, body composition \u00a3490\n\u2022 Ultrasound: from \u00a3320 (one part), from \u00a3400 (two parts)\n\u2022 ECG: resting \u00a3105, stress ECG \u00a3275\n\u2022 Echocardiogram: \u00a3400 / CPET: \u00a3595\n\u2022 3D Body Scan: \u00a3120-\u00a3150 / DNA Life profile: from \u00a3860\n\u2022 Blood testing: from \u00a350; comprehensive profiles \u00a3297-\u00a380\u2026","No. of Membership Tiers":"6","Loyalty Scheme? (0/1)":null,"Membership Detail":"Lanserhof at The Arts Club operates as a standalone medical wellness members\u2019 club (separate from The Arts Club), though existing Arts Club members can add Lanserhof access. Non-members may also access the medical clinic and treatments, while gym, studio classes, and Members\u2019 Lounge require membership. \nMedical Team - Lanserhof at The\u2026\nMembership Tiers (6)\n1. Full Membership \u2014 London-based individuals\nIncludes: unlimited gym and studio classes, Members\u2019 Lounge access, member pricing on medical s\u2026","Joining Fee":"2016","Minimum Membership Price ($ per month)":"453.57","Maximum Membership Price ($ per month)":"690","Product/Retail? (0/1)":"1","Product/Retail Detail":"On-site retail/product offering:\n\n1. LANS Derma products \u2014 in-house skincare products available in changing rooms (confirmed by Evening Standard).\n\n2. Bioniq personalised supplements \u2014 prescribed foll\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"N/A \u2014 Lanserhof at The Arts Club is a day-visit urban clinic with no accommodation. Revenue is driven by membership fees, \u00e0 la carte treatments and programme fees.\n\nHowever, all Lanserhof at The Arts Club members receive 10% off room rates at Lanserhof destination resorts (Lans, Tegernsee, Sylt, Mar\u2026","Other Fees":"1. Joining fee: \u00a31,600 (one-off, for Full membership; \"member assessment\" per Harper's Bazaar).\n2. Butler service (sportswear laundry): reported \u00a31,000/year (Evening Standard 2019).\n3. Non-member surc\u2026","What does this brand prove about scale?":"Shows a destination clinic can urbanise through a members' club without fully losing medical credibility.","What does it prove about room-to-wellness ratios?":"Very dense for central London: small footprint, high medical and performance intensity.","What does it prove about diversification logic?":"Adds membership, corporate and outpatient revenue; continuity layer, not full destination replacement.","Notes / Observations":"Urban continuity for the Lanserhof method: strong outpatient credibility, but convenience and retention outweigh immersion."},{"Brand / Expression":"BodySpace at Mandarin Oriental Hyde Park","Operator / Hosted Within":"Mandarin Oriental Hotel Group / BodySpace","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"London, UK","Core Positioning":"Luxury Wellness Retreat","Target Segments":"HNW, UHNW, Affluent Wellness","Price Tier (1-5)":"4","Est":"2023","Description":"BodySpace is a performance and lifestyle wellness programme embedded within the Spa at Mandarin Oriental Hyde Park, London, launched in 2023 by wellness consultant Stephen Price and performance coach David Higgins.\nImportantly, it is not a standalone clinic or dedicated facility, but a branded partnership operating within the hotel\u2019s spa infrastructure, which includes 17 treatment/consultation roo\u2026","Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Individual Wellness, High Performance, Opportunistic Hotel Guest","Clinical Grade (1\u20135)":"1","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"No specified dedicated area, more of a branded integration within the spa facility","Clinical & Treatment Rooms":"0","Clinical & Treatment Rooms Detail":"No dedicated/owned treatment rooms, but the spa facility at the hotel has 17\n\nPost-2018 renovation (current layout, per the Spa & Wellness press release):\n        \u2022        13 treatment rooms (including the Oriental Suite with two massage beds and a Rasul water temple)\n        \u2022        1 ASANTE Chinese Medicine consultation/treatment room\n        \u2022        1 Bastien Gonzalez Pedi:Mani:Cure Studio\n  \u2026","No. of Specialist Facilities":"19","Specialist Facilities/Equipment":"Diagnostics & Imaging (1)\nVISIA skin analysis imaging system for multi-spectral facial diagnostics and skin-age benchmarking. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (0)\nNo confirmed on-site laboratory infrastructure; blood panels referenced in programmes are processed externally. \n\nIV / Infusion Infrastructure (0)\nNo dedicated IV infusion suites or infusion-specific equipment confirmed at the Hyde Park site. \n\nLongevity Tech / Biohacking (7)\nEMS (electro muscle stimulation) training\u2026","External Medical Partnership?":"Formal clinical partnership with the Institute of Sport, Exercise & Health (ISEH) providing off-site cardiology and performance diagnostics (ECG, echocardiography, CPET, isokinetic testing, force plates) and sports medicine specialists; operates alongside a Clinique La Prairie longevity partnership \u2026","Rooms":"0","Host Hotel Rooms":"181","Branded Residences":"0","Total Feeder Units":"109","External Feeder Units":"50","Wellness Area per Key":null,"Revenue Drivers":"Treatment-led, Membership-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"Three hotel restaurants and one bar, all available to BodySpace members (10% discount):\n\n1. Dinner by Heston Blumenthal \u2014 two Michelin stars. Historical British cuisine in a contemporary setting with views of Hyde Park.\n\n2. The Aubrey \u2014 traditional Japanese izakaya dining.\n\n3. The Rosebery \u2014 award-w\u2026","Medical Licensing Model":null,"On-Site Doctors":"0","Total Specialist Count":"15","Specialist Staff Details":"Approximately 15-20 wellness practitioners across BodySpace coaching team and spa therapists. No medical doctors on-site. Key named practitioners:\n\nBodySpace Leadership:\n\u2022 Stephen Price \u2014 Co-Founder, wellness consultant (20+ years), SP&Co founder. Background in luxury hotel wellness consulting, medical wellness, oncology support. Created Movementum concept and Firstbeat HRV monitoring programme.\n\u2022\u2026","External Doctors":"0","Specialists / 10,000 sq ft":null,"Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"BodySpace itself operates as a partnership/concession within the hotel's existing spa \u2014 the capex for BodySpace-specific elements (Movementum Studio, Hyperice recovery area, EMS equipment, Firstbeat monitoring devices) is relatively modest compared to building standalone wellness facilities.\n\nThe un\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Treatment","Offering Type Secondary":"Membership","No. of Programmes":"8","Programme Detail":"BodySpace Intensive Optimisation Programmes:\n1. 6-Week Optimisation Programme \u2014 \u00a33,240:\n\u2022 One lifestyle performance profile assessment\n\u2022 One body and movement analysis\n\u2022 One nutritional consultation and follow-up\n\u2022 60-day nutrition plan + 30-day personalised supplement plan\n\u2022 10 Lifestyle Performance coaching multi-use credits (in-person or online)\n\u2022 Two recovery compression treatments\n\u2022 One Bodyspace lifestyle performance spa treatment\n\u2022 One assessment with the programme director\n\n2. 12-Week Op\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"84","Minimum Programme Price ($)":"542","Maximum Programme Price ($)":"7484","No. of \u00c0 la Carte Treatments":"40","Minimum Treatment Price ($)":"107","Maximum Treatment Price ($)":"876","Treatment Details":"Comprehensive spa treatment menu (~40+ treatments, prices in GBP):\n\nSIGNATURE THERAPIES:\n\u2022 Time Rituals\u2122 (bespoke): 2hrs \u00a3380, 3hrs \u00a3540\n\u2022 Oriental Harmony (2hrs): \u00a3525\n\u2022 Oriental Qi (1.5hrs): \u00a3305\n\u2022 Acupuncture (1hr): \u00a3230\n\u2022 Manual Lymphatic Drainage (1.5hrs): \u00a3350\n\u2022 Naturopath Consultation (1hr): \u00a3250\n\nFACIALS:\n\u2022 Biologique Recherche Remodelling Face (1.5hrs): \u00a3390\n\u2022 OSKIA Sub-Zero Cryotherapy Facial (1.5hrs): \u00a3360\n\u2022 OSKIA Signature Facial (1.5hrs): \u00a3290\n\u2022 Skin Instant\u00ae Lab (30m): \u00a385\n\nBODY TR\u2026","No. of Membership Tiers":"1","Loyalty Scheme? (0/1)":"0","Membership Detail":"One primary membership tier at Mandarin Oriental Hyde Park:\n\n12-Month Bodyspace Club Membership:\n\u2022 Annual fee: \u00a33,950 (~$4,977)\n\u2022 Joining fee: \u00a3750 (~$945) \u2014 one-off\n\u2022 Total first year: \u00a34,700 (~$5,922)\n\nAccess:\n\u2022 Technogym gymnasium: 24/7\n\u2022 17-metre stainless-steel swimming pool: 6:30am-9:30pm\n\u2022 Spa thermal facilities (sauna, steam room, vitality pool): 9am-9pm\n\nFitness Benefits:\n\u2022 One-to-one coaching session (including orientation)\n\u2022 One swimming stroke analysis\n\u2022 Ten Movementum classes\n\nGuest\u2026","Joining Fee":"945","Minimum Membership Price ($ per month)":"414.75","Maximum Membership Price ($ per month)":"414.75","Product/Retail? (0/1)":"1","Product/Retail Detail":"On-site retail and product offerings:\n\n1. Biologique Recherche skincare \u2014 French clinical skincare brand, used in treatments and available for purchase.\n2. OSKIA \u2014 British natural skincare brand, used\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Strong room-rate integration \u2014 The Spa at Mandarin Oriental Hyde Park is a core amenity of the hotel and a significant driver of guest satisfaction and premium room rates.\n\n\u2022 Hotel guests have complimentary access to the swimming pool, fitness centre, and thermal facilities.\n\u2022 Spa treatments, BodySp\u2026","Other Fees":"1. BodySpace joining fee: \u00a3750 (one-off).\n2. Multi-use credits: \u00a3180/credit (bulk discounts: 10 for \u00a31,700; 25 for \u00a34,125; 50 for \u00a37,750).\n3. In-room coaching: \u00a3250/hr (premium over standard \u00a3180/cred\u2026","What does this brand prove about scale?":"A boutique operator can leverage hotel-group scale through partnerships rather than owned real estate.","What does it prove about room-to-wellness ratios?":"Good city-hotel wellness density, but still secondary to the host hotel ecosystem.","What does it prove about diversification logic?":"Low-capex layering: membership, coaching and partner services lift yield from existing spa space.","Notes / Observations":"Premium performance layer inside a hotel spa: commercially smart and low-capex, but too light clinically for serious longevity."},{"Brand / Expression":"Lefay Resort & SPA Dolomiti","Operator / Hosted Within":"Lefay Resorts & Residences","Level / Category":"A \u2014 Mothership","Status":"Established","Location City, Country":"Pinzolo (Trentino), Italy","Core Positioning":"Integrative Healing","Target Segments":"HNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2019","Description":"Lefay Resort & SPA Dolomiti is a luxury wellness resort located in Pinzolo within the Madonna di Campiglio ski area of the Italian Dolomites, opened in 2019 as the second property in the Lefay Resorts & Residences collection. Founded by Alcide and Liliana Leali, the brand combines high-end wellness hospitality with strong environmental sustainability principles.\nThe resort features 88 suites, bran\u2026","Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Individual Wellness, Family / Multi-Gen, High Performance","Clinical Grade (1\u20135)":"2","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"0","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"53820","Clinical & Treatment Rooms":"22","Clinical & Treatment Rooms Detail":"Over 20 treatment rooms plus 2 Private SPAs for couples (Lefay meeting factsheet, 2024):\n\n\u2022 Treatment rooms for Lefay SPA Signature energy massages, face and body aesthetic rituals, and energy-therapeutic path treatments\n\u2022 Non-invasive aesthetic medicine rooms (HydraFacial MD, Observ 320, Indiba radio-frequency, VelaShape, Intraceuticals Oxygen Therapy, ZO Skin Health)\n\u2022 Physiotherapy and osteopat\u2026","No. of Specialist Facilities":"5","Specialist Facilities/Equipment":"Diagnostics & Imaging (0)\nNo confirmed clinical diagnostic or imaging platforms (e.g., MRI, ultrasound, ECG, DEXA) installed on-site. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (0)\nNo on-site laboratory or phlebotomy infrastructure documented; consultations within programmes are holistic/TCM-based rather than laboratory diagnostics. \n\nIV / Infusion Infrastructure (0)\nNo IV suites, infusion chairs, or infusion delivery systems confirmed at the Dolomiti property. \n\nLongevity Tech / Biohac\u2026","External Medical Partnership?":"No","Rooms":"88","Host Hotel Rooms":"0","Branded Residences":"21","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Room-led, Treatment-led, Programme-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"Two dedicated restaurants, plus bars and lounges:\n\n1. Dolomia Restaurant \u2014 main restaurant offering buffet breakfast, \u00e0 la carte lunch and dinner. Local/Mediterranean/seasonal cuisine. Smart casual dress code. Open daily for lunch; dinner on seasonal basis.\n\n2. Grual Organic Restaurant \u2014 Michelin-st\u2026","Medical Licensing Model":"Light-touch medical","On-Site Doctors":"0","Total Specialist Count":"Undisclosed","Specialist Staff Details":"The exact number of specialist practitioners at Lefay Resort & SPA Dolomiti is not publicly disclosed. The resort employs ~155 total staff across all departments, but no detailed breakdown of spa, medical, or therapeutic roles is published. \nPasted text\nThe clinical framework is guided by the Lefay SPA Method Scientific Committee, a visiting group of physicians and integrative medicine specialists\u2026","External Doctors":"3","Specialists / 10,000 sq ft":null,"Build Typology":"Purpose-built clinic","Indicative Capex Intensity":"Purpose-built luxury eco-spa resort constructed 2017-2019 by architect Hugo Demetz (bio-architecture exterior) and Alberto Apostoli (interiors). Nine-level structure set into the mountainside using traditional materials (wood, stone) with advanced energy/water management systems. ClimaHotel certifie\u2026","Perceieved Capital Intensity Level (1-3)":"3","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"11","Programme Detail":"Lefay SPA Method Programmes (excl. accommodation):\n\n1. Active & Balance \u2014 5 nights (\u20ac2,590): full board with Lefay SPA Menu, welcome body scrub, medical examination with acupuncture, fitness consultation, phytotherapy, 5 themed days (Green Dragon, Red Phoenix, White Tiger, Black Tortoise, Centre) with outdoor activities + spa treatments + energy balancing activities. Final examination.\n\n2. Active & Balance Short \u2014 3 nights (\u20ac1,090): condensed version with 2 themed days, fitness consultation, phy\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"5","Minimum Programme Price ($)":"338","Maximum Programme Price ($)":"2823","No. of \u00c0 la Carte Treatments":"80","Minimum Treatment Price ($)":"60","Maximum Treatment Price ($)":"665","Treatment Details":"Comprehensive treatment menu (~80+ treatments, prices in EUR, MON-THU/FRI-SUN):\n\nLEFAY SPA SIGNATURE ENERGY MASSAGES:\n\u2022 Scambio nel Vento (Relaxing, 50 min): \u20ac125/\u20ac137\n\u2022 La Quiete (Antistress, 65 min): \u20ac155/\u20ac170\n\u2022 Il Volo della Farfalla (Four Hands, 50 min): \u20ac220/\u20ac240\n\u2022 Dell'Imperatore (Body/Head, 80 min): \u20ac170/\u20ac185\n\nENERGY-THERAPEUTIC PATHS (CCM-based):\n\u2022 Green Dragon/Red Phoenix: \u20ac285 each\n\u2022 White Tiger: \u20ac320\n\u2022 Black Tortoise: \u20ac330\n\nNON-INVASIVE AESTHETIC MEDICINE:\n\u2022 HydraFacial MD: \u20ac220-\u20ac320\n\u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"0","Membership Detail":"No proprietary Lefay membership programme. The resort participates in the Preferred Hotels & Resorts \"I Prefer\" loyalty programme, offering benefits including early check-in, late check-out, room upgrade subject to availability, and points earning on stays. No dedicated spa or wellness membership available.","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"1","Product/Retail Detail":"On-site retail via Lefay SPA Shop (also available online at lefayshop.com):\n\n1. Lefay SPA \"Tra Suoni e Colori\" cosmetic line \u2014 proprietary natural dermatological cosmetics (face and body products). Ni\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Full room-rate integration \u2014 the spa is the core of the resort proposition, not an amenity.\n\n\u2022 All hotel guests have complimentary access to the 5,000 sqm Lefay SPA World including pools, saunas, fitness centre, relaxation areas, and group classes.\n\u2022 Salt-water lake \"L'Aurora nel Lago\" requires sepa\u2026","Other Fees":"1. Salt-Water Lake \"L'Aurora nel Lago\": \u20ac50-55/person (40 min), \u20ac90-99/couple.\n2. Weekend/holiday spa surcharge: ~10% above weekday treatment prices.\n3. Personal trainer: \u20ac90-110 (40-50 min).\n4. Pet f\u2026","What does this brand prove about scale?":"Selective resort growth can still build a credible brand if execution and positioning stay consistent.","What does it prove about room-to-wellness ratios?":"Oversized spa-to-key ratio signals wellness leads the guest proposition, not the room count.","What does it prove about diversification logic?":"Conservative layering through residences, retail and a small portfolio - not aggressive format spread.","Notes / Observations":"Spa-first integrative destination with strong design and sustainability, but lighter clinically than the medical leaders."},{"Brand / Expression":"Next Health, West Hollywood (Los Angeles, CA, USA)","Operator / Hosted Within":"Next Health Inc.","Level / Category":"Local \u2014 Standalone","Status":"Established","Location City, Country":"West Hollywood, Los Angeles, California, USA","Core Positioning":"Performance / Biohacker","Target Segments":"High Performance / Biohacker, Affluent Wellness","Price Tier (1-5)":"2","Est":"2016","Description":"Next Health is a health optimisation and longevity clinic founded in 2016 by surgeon Dr. Darshan Shah and entrepreneur Kevin Peake, positioned around data-driven, preventative health and technology-led therapies. The original flagship is located on Sunset Boulevard in West Hollywood, within a mixed-use wellness and lifestyle campus on the Sunset Strip.\nThe clinic operates a membership-led, \u00e0-la-ca\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"High Performance, Individual Wellness","Clinical Grade (1\u20135)":"3","Residential (0/1)":"0","Hotel Guest (0/1)":"0","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"178699","Total GFA (sq ft)":"10000","Stated Wellness/Clinical Area (sq ft)":"10000","Clinical & Treatment Rooms":"15","Clinical & Treatment Rooms Detail":"The ~10,000 sq ft flagship facility contains an estimated 13\u201318 treatment spaces, based on multiple sources (tour videos, franchise documents, reviews, and service listings).\n\nBreakdown (estimated):\nWellness technology rooms: 4\u20136\n(cryotherapy chamber, hyperbaric oxygen chamber(s), infrared sauna room(s), red-light therapy room)\n\nIV / infusion areas: 3\u20134\n(1 IV lounge with ~6\u20138 chairs + 2\u20133 private \u2026","No. of Specialist Facilities":"15","Specialist Facilities/Equipment":"Diagnostics & imaging: 2\n(InBody body composition analyser; VISIA facial skin analysis system)\n\nLabs & testing: 1\n(On-site blood draw / phlebotomy station; samples processed off-site)\n\nRegenerative / blood therapy infrastructure: 2\n(EBOO extracorporeal blood oxygenation system; therapeutic plasma exchange centrifuge)\n\nIV / infusion infrastructure: 3\n(IV therapy lounge, private infusion rooms, NuCalm neuroacoustic system)\n\nLongevity / biohacking technology: 4\n(whole-body cryotherapy chamber, hype\u2026","External Medical Partnership?":"Operates a hybrid model: core longevity treatments are delivered in-house, while advanced diagnostics rely on external partners.\n\nImaging: Full-Body MRI likely conducted via Prenuvo; CT scans (chest, calcium score) referred to external imaging centres.\nLaboratory testing: Blood drawn on-site but pro\u2026","Rooms":"0","Host Hotel Rooms":"0","Branded Residences":"0","Total Feeder Units":"726","External Feeder Units":"0","Wellness Area per Key":"13.77410468","Revenue Drivers":"Membership-led, Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"0","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":null,"F&B Detail":"Next Health does not operate any food and beverage concept. The clinic is a pure treatment and technology centre with no restaurant, juice bar, caf\u00e9, or food service.\n\nAdjacent F&B options at The Sunset complex and Sunset Strip (not operated by Next Health):\n\u2022 Sweetgreen \u2014 adjacent tenant at The Sun\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"1","Total Specialist Count":"15","Specialist Staff Details":"The West Hollywood flagship (~10,000 sq ft) is estimated to operate with 10\u201315 (COO Scott Svilich quoted as saying for each location) specialist clinical and wellness staff, higher than standard franchise units due to its broader services (e.g., TPE, advanced aesthetics, large IV lounge).\n\nDoctors \u2014 1\u20132\nDr. Anna Emanuel (MD) \u2014 Confirmed Medical Director for the LA locations (West Hollywood, Centur\u2026","External Doctors":"0","Specialists / 10,000 sq ft":"15","Build Typology":"Urban conversion","Indicative Capex Intensity":"Next Health Franchise Initial Investment (per 2025 FDD):\n\u2022 Total initial investment: $1,690,200 - $2,259,200\n\u2022 Initial franchise fee: $80,000\n\u2022 Multi-unit development fee: $90,000-$120,000 (for 3-6 centres)\n\u2022 Build-out and equipment within the investment range\n\nKey Equipment Costs (estimated, typica\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Membership","Offering Type Secondary":"Treatment","No. of Programmes":"3","Programme Detail":"Next Health does not offer fixed multi-day residential programmes. Instead, it operates a membership + \u00e0-la-carte model, where clients build personalised health protocols through recurring visits.\n\nStructured Offerings\n1. Executive Physical ($14,500\u2013$15,995 \u2014 1-year programme)\nComprehensive diagnostic programme including Full-Body MRI, Chest CT, 500+ biomarker testing, and 1:1 physician consultations with ongoing monitoring over 12 months.\n\n2. Weight Optimisation Programme (price via consultatio\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"365","Minimum Programme Price ($)":"99","Maximum Programme Price ($)":"15995","No. of \u00c0 la Carte Treatments":"50","Minimum Treatment Price ($)":"49","Maximum Treatment Price ($)":"14500","Treatment Details":"VITAMIN SHOTS ($49 each, 5-10 min):\n\u2022 Super B, Lean B (Metabolism), CoQ10 (Heart/Energy), Brain B, Beauty B, Vitamin D, Limitless (NAD+ blend), Glutathione\n\nIV THERAPY (30-60 min):\n\u2022 Hydration ($99), Targeted Drips ($199): Super Immune, Longevity, Hangover, Stress, Glamour, Detox, Muscle, Weight Loss, Energy Plus, Brain, Gut Health, Lean\n\u2022 Plaquex ($300), High-Dose Vitamin C ($300-$375)\n\nNAD+ THERAPY (2-3 hrs):\n\u2022 NAD+ 300mg ($500), 750mg ($1,000), Niagen 500mg-1,000mg ($1,200-$2,000)\n\nWELLNESS T\u2026","No. of Membership Tiers":"6","Loyalty Scheme? (0/1)":"0","Membership Detail":"Next Health offers 6 membership tiers:\n\n1. MEDICINE 4.0 ($99/month):\n   Foundational tier. Quarterly biomarker/functional testing, 1:1 consultations with medical providers, access to prescribed peptides and hormones (BHRT, weight optimization), exclusive member pricing on all services.\n\n2. OPTIMIZE ($199/month):\n   1 Vitamin Shot per month, 10 Next|Tech Credits (Cryo=1, Infrared Sauna=2, LED Bed=3, HBOT=7), exclusive member pricing.\n\n3. PREMIER ($299/month \u2014 most popular):\n   2 IV Therapy sessio\u2026","Joining Fee":"Not disclosed (founding member offers at new locations include 20-50% monthly discounts)","Minimum Membership Price ($ per month)":"99","Maximum Membership Price ($ per month)":"8333","Product/Retail? (0/1)":"1","Product/Retail Detail":"Next Health operates a dedicated e-commerce retail platform at NextHealthShop.com with 29 products:\n\nSUPPLEMENTS & BUNDLES:\n\u2022 Blood Pressure Bundle: $199.99 (was $239.95)\n\u2022 Blood Sugar Bundle: $109.99\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Not applicable \u2014 Next Health West Hollywood is a standalone urban clinic with no hotel component. There are no room rates, hotel packages, or accommodation tie-ins.\n\nFor context, Next Health does have a location at Atlantis Dubai (international expansion), but the West Hollywood flagship operates in\u2026","Other Fees":"1. Franchise Fee: $80,000 (initial; for new franchisees \u2014 not a consumer fee)\n2. Multi-Unit Development Fee: $90,000-$120,000 (for 3-6 centres)\n3. Total Initial Investment: $1,690,200-$2,259,200 (fran\u2026","What does this brand prove about scale?":"Urban longevity scales fastest through repeatable clinic units and a franchise-friendly operating model.","What does it prove about room-to-wellness ratios?":"No-room economics maximise wellness throughput, but sacrifice destination-style immersion and containment.","What does it prove about diversification logic?":"Strong breadth across memberships, treatments and aesthetics, though positioning risks becoming diffuse.","Notes / Observations":"Scalable urban clinic network built on memberships and treatment frequency; commercially strong, but not destination wellness."},{"Brand / Expression":"Next Health Dubai (Business Bay, Dubai, UAE)","Operator / Hosted Within":"Next Health Inc. / SAAS Health (UAE franchise)","Level / Category":"Local \u2014 Standalone","Status":"New / Opening Soon","Location City, Country":"Dubai, United Arab Emirates","Core Positioning":"Performance / Biohacker","Target Segments":"High Performance / Biohacker, HNW","Price Tier (1-5)":"3","Est":"2025","Description":"Next Health Dubai is the brand\u2019s first international longevity and health-optimisation centre, bringing the Los Angeles flagship concept to Business Bay. Founded by Dr Darshan Shah and Kevin Peake, the brand focuses on data-driven preventative health, combining diagnostics, biomarker analysis, and advanced therapies within a premium, membership-led clinic environment.\n\nThe Dubai location replicate\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"High Performance, Individual Wellness","Clinical Grade (1\u20135)":"3","Residential (0/1)":"0","Hotel Guest (0/1)":"0","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"Not disclosed","Stated Wellness/Clinical Area (sq ft)":"Not disclosed","Clinical & Treatment Rooms":"15","Clinical & Treatment Rooms Detail":"Next Health Dubai does not publish a full floor plan, but based on its service menu and membership offerings the facility can be interpreted as containing ~12\u201315 clinical and treatment spaces organised across several functional zones. \n\nConsultation & diagnostics (\u22484\u20135 spaces)\nIncludes functional medicine consultation rooms, nutrition consultation, a phlebotomy/blood-draw station for biomarker tes\u2026","No. of Specialist Facilities":"18","Specialist Facilities/Equipment":"Diagnostics & Imaging (3)\nAI skin analysis scanner, body composition scanners (SmartBody / InBody) used for aesthetic and metabolic assessment.\n\nLabs & Advanced Testing (1)\nOn-site blood draw and biomarker testing infrastructure; laboratory analysis processed externally.\n\nRegenerative / Cell Therapy (2)\nStem cell treatment suite and PRP centrifuge system for regenerative therapies.\n\nIV / Infusion Infrastructure (2)\nDedicated IV therapy lounge plus private infusion rooms for longer treatments suc\u2026","External Medical Partnership?":"Next Health Dubai operates largely self-contained for core longevity and wellness services, but relies on unnamed external partners for certain specialised functions. These include advanced imaging (MRI and CT scans) referenced in programmes but not available on-site, as well as laboratory processin\u2026","Rooms":"0","Host Hotel Rooms":"0","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"400","Wellness Area per Key":null,"Revenue Drivers":"Membership-led, Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"0","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":null,"F&B Detail":"Next Health Dubai does not operate any food and beverage concept. The clinic is a pure treatment and technology centre with no restaurant, juice bar, caf\u00e9, or food service.\n\nThe Sonder Business Bay tower includes a restaurant and food outlets (per property listings), and Business Bay offers extensiv\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"2","Total Specialist Count":"15","Specialist Staff Details":"Next Health Dubai has three identifiable clinical staff from public sources: two doctors \u2014 Dr. Aya Alsaiem (GP, dermatology & aesthetics) and Dr. Syeda Irsa Maqbool (functional & regenerative medicine) \u2014 plus one Head Nurse (Melissa Hachem). Several additional roles (functional medicine providers, clinical nutritionists, aesthetic doctors) are referenced in materials but no individuals are publicl\u2026","External Doctors":"Collaborating with \"renowned local practitioners\" for functional medicine (per One Ville News, June 2025); specific names not disclosed","Specialists / 10,000 sq ft":null,"Build Typology":"Urban conversion","Indicative Capex Intensity":"Next Health Dubai Franchise Investment:\n\u2022 US franchise model: total initial investment $1,690,200-$2,259,200 (per 2025 FDD)\n\u2022 International franchise terms (Dubai) are not publicly disclosed and may differ from the US FDD figures due to import costs, local construction, DHA licensing, and market ada\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Membership","Offering Type Secondary":"Treatment","No. of Programmes":"3","Programme Detail":"Next Health Dubai does not offer fixed multi-day residential programmes. Instead, like the LA flagship, it operates a membership + \u00e0-la-carte model, where clients build personalised longevity protocols through recurring visits.\n\nStructured Offerings\n1. Executive Physical (AED 65,000 \u2014 ~1-year programme)\nComprehensive diagnostic and optimisation programme including full-body MRI, CT scans, DEXA, 500+ biomarker and genetic tests, plus ongoing functional medicine and nutrition consultations over 12\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"365","Minimum Programme Price ($)":"545","Maximum Programme Price ($)":"17700","No. of \u00c0 la Carte Treatments":"50","Minimum Treatment Price ($)":"109","Maximum Treatment Price ($)":"Not disclosed","Treatment Details":"FUNCTIONAL MEDICINE:\n\u2022 Initial Consultation (60 min): AED 1,000 / AED 800 members\n\u2022 Follow-up Consultation: AED 600 / AED 480 members\n\u2022 Covers: obesity, diabetes, hormonal imbalances, GI issues, autoimmune, preventive care\n\nIV & IM VITAMIN THERAPY:\n\u2022 12+ IV drip formulations: Super Immune, Energy Plus, Detox, Glamour (Hair/Skin/Nails), Longevity, Hangover, Stress, Muscle (Recovery), Weight Loss, Brain (Focus), Gut Health, Lean\n\u2022 Vitamin Shots: Limitless (NAD+), Lean B, CoQ10, Brain B, Beauty B, \u2026","No. of Membership Tiers":"5","Loyalty Scheme? (0/1)":"0","Membership Detail":"Next Health Dubai offers 5 membership tiers with a minimum 3-month commitment:\n\n1. OPTIMIZE (AED 1,999/month, ~$545):\n   SmartBody Analysis, Skin Analysis, Baseline Tests, 1 Monthly Vitamin Shot, 10 Monthly Optims. Up to 20% off select services.\n\n2. PREMIUM (AED 2,999/month, ~$817):\n   SmartBody Analysis, Skin Analysis, Baseline Tests, 2 Monthly Vitamin Shots, 2 Monthly IV Vitamin Therapies, 20 Monthly Optims. Up to 20% off.\n\n3. GLOW (AED 3,999/month, ~$1,089):\n   Aesthetics-focused. SmartBody &\u2026","Joining Fee":"Not disclosed (minimum 3-month commitment required)","Minimum Membership Price ($ per month)":"545","Maximum Membership Price ($ per month)":"1361","Product/Retail? (0/1)":"0","Product/Retail Detail":"The Next Health Dubai website (nexthealth.ae) does not include a retail/shop section or list any products for sale. Unlike the US operation, which has NextHealthShop.com with 29 products (supplements,\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"No room-rate integration exists between Next Health Dubai and Sonder Business Bay despite being co-located in the same tower (SAAS Tower). Next Health occupies Shop 1 (ground-floor retail unit) as an independent tenant.\n\nSonder Business Bay operates 401 serviced apartments (studios to 3-bedrooms) av\u2026","Other Fees":"1. Minimum 3-month membership commitment required (all tiers)\n2. Members receive up to 20% off: Stem Cells, Exosomes, Aesthetic Treatments, NAD+ IV, Lab Testing\n3. Executive Physical: 20% discount on \u2026","What does this brand prove about scale?":"Proves the US clinic model exports to Dubai and can command a regional price premium.","What does it prove about room-to-wellness ratios?":"Again a pure no-room clinic: utilisation and repeat visits matter more than space-to-key balance.","What does it prove about diversification logic?":"Memberships and aesthetics broaden revenue, but the model remains frequency-led rather than journey-led.","Notes / Observations":"US clinic playbook translated to Dubai: data-led and premium-priced, with strong membership logic but limited programme depth."},{"Brand / Expression":"Next Health at Four Seasons Resort Maui (Wailea, HI, USA)","Operator / Hosted Within":"Next Health Inc. / Four Seasons Resort Maui","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Maui, Hawaii, USA","Core Positioning":"Performance / Biohacker","Target Segments":"HNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2021","Description":"Next Health at Four Seasons Resort Maui at Wailea is a luxury wellness collaboration between Next Health and the beachfront resort, launched in 2021 following the reopening of Hawaii to international travel. The partnership brings Next Health\u2019s longevity and health-optimisation services into a hospitality setting, offering guests access to medical-grade wellness treatments during their stay.\nServi\u2026","Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Opportunistic Hotel Guest, Individual Wellness","Clinical Grade (1\u20135)":"2","Residential (0/1)":"0","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"0","Total Site Area (sq ft)":"653400","Total GFA (sq ft)":"635976","Stated Wellness/Clinical Area (sq ft)":"840","Clinical & Treatment Rooms":"1","Clinical & Treatment Rooms Detail":"The space is consistently described as a single \u201cIV Lounge\u201d rather than a multi-room clinical facility. Next Health\u2019s own website refers to guests being \u201cguided to our luxury IV lounge\u201d in the Ali\u2019i Room, and InsideHook describes the reporter \u201csitting in a plush leather chair, feet up, looking towards the Pacific Ocean\u201d. The Four Seasons press release and Forbes coverage consistently refer to it a\u2026","No. of Specialist Facilities":"4","Specialist Facilities/Equipment":"Diagnostics & Imaging (0)\nNo diagnostic imaging or scanning equipment confirmed at this site (e.g., MRI, DEXA, ultrasound, or body composition scanners).\n\nLabs & Advanced Testing (1)\nOn-site phlebotomy station for biomarker testing and blood collection; laboratory analysis is processed externally through partner labs.\n\nRegenerative / Cell Therapy (1)\nOzone therapy unit used for extracorporeal blood oxygenation as part of regenerative wellness treatments.\n\nIV / Infusion Infrastructure (2)\nIV loun\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"380","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Treatment-led, Membership-led","Integrated F&B Concept? (0/1)":"0","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":null,"F&B Detail":"Next Health at Four Seasons Maui does not operate any food and beverage concept. It provides clinical/treatment services only.\n\nThe Four Seasons Resort Maui offers three restaurants available to all guests:\n1. Ferraro's Bar e Ristorante \u2014 Italian oceanfront dining (directly adjacent to Next Health's\u2026","Medical Licensing Model":"Light-touch medical","On-Site Doctors":"1","Total Specialist Count":"4","Specialist Staff Details":"Next Health at Four Seasons Maui operates with a very small clinical team consistent with its IV-lounge format. The site is overseen by Dr. Kyle Maehara (Medical Director), a regenerative and anti-aging physician based in Honolulu who provides medical oversight and prescribing authority but is not permanently on-site.\n\nDay-to-day services are delivered by one nurse practitioner supported by a smal\u2026","External Doctors":"2","Specialists / 10,000 sq ft":"47.61904762","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"Next Health at Four Seasons Maui \u2014 Estimated Capital Intensity:\n\nThe Maui embedded offering requires minimal dedicated capital expenditure because:\n\u2022 No permanent wellness technology installations (no cryotherapy, hyperbaric, infrared equipment)\n\u2022 The Ali'i Room is an existing resort room repurposed\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Treatment","Offering Type Secondary":"Membership","No. of Programmes":"0","Programme Detail":"Next Health at Four Seasons Maui does not offer structured multi-day programmes. All services are available on an individual, \u00e0 la carte basis.\n\nThe closest to a \"programme\" offering is:\n1. JET LAG RELIEF PACK \u2014 a curated combination of IV Hydration + Glutathione Add-On + NAD+ designed to be taken on arrival day to combat travel fatigue and dehydration\n\nAll other services (IV drips, regenerative therapies, biomarker tests, acupuncture, chiropractic) are single-session bookings. Guests may combin\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"1","Minimum Programme Price ($)":"Not applicable [no formal programmes; individual treatments from $59 (vitamin shot)]","Maximum Programme Price ($)":"Not applicable [no formal programmes; most expensive individual treatment is Stem Cell Therapy at $10,000]","No. of \u00c0 la Carte Treatments":"34","Minimum Treatment Price ($)":"59","Maximum Treatment Price ($)":"10000","Treatment Details":"VITAMIN SHOTS ($59 each, 15 min):\n\u2022 Super B Shot, Brain B Shot, Beauty B Shot, Limitless Shot, Lean B Shot, CoQ10 Shot\n\nIV THERAPY ($299 each, 30 min \u2014 all include Myers Cocktail base):\n\u2022 Hangover IV \u2014 toxin elimination, liver support, detox\n\u2022 Glamour IV \u2014 collagen-boosting vitamin C, l-Lysine, biotin for hair/skin/nails\n\u2022 Energy Plus IV \u2014 L-Carnitine, B12, amino acids for performance\n\u2022 Super Immune IV \u2014 vitamin C, magnesium, B5, antivirals for immune defence\n\u2022 Detox IV \u2014 system cleanse, skin cl\u2026","No. of Membership Tiers":"6","Loyalty Scheme? (0/1)":"0","Membership Detail":"Next Health memberships are cross-location across the Next Health clinic network (e.g. Los Angeles, New York, Miami, Dubai). However, the Four Seasons Resort Maui at Wailea outpost is not a full clinic, meaning many membership benefits are not usable there.\n\nCurrent tiers (2025\u20132026):\nMedicine 4.0 \u2014 $99/month\nBiomarker testing, physician consultations, and access to peptide/hormone optimisation programmes.\n\nOptimize \u2014 $199/month\n1 vitamin shot/month plus 10 tech credits (e.g. cryotherapy, infrar\u2026","Joining Fee":"Not disclosed (founding member offers at new locations include 20-50% monthly discounts; no explicit joining fee published)","Minimum Membership Price ($ per month)":"99","Maximum Membership Price ($ per month)":"8333","Product/Retail? (0/1)":"0","Product/Retail Detail":"No physical retail or product sales at the Four Seasons Maui location. Next Health operates an e-commerce platform (NextHealthShop.com) with supplements, at-home test kits, and bundles, but these are \u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Next Health services at Four Seasons Resort Maui are separately priced and billed \u2014 they are NOT included in room rates or resort packages.\n\nBooking: Appointments required, booked by calling the resort at (808) 874-8000 or calling/texting Next Health directly at (808) 874-2925.\n\nFour Seasons Maui ro\u2026","Other Fees":"1. All services subject to Hawaii General Excise Tax (GET) at 4.166%\n2. Gratuity customary for spa/wellness services (not mandatory)\n3. Medical Clearance Form required for guests over 69 years old (no\u2026","What does this brand prove about scale?":"A resort outpost extends reach, but this is brand visibility more than true operating scale.","What does it prove about room-to-wellness ratios?":"Extremely light versus the host resort; it behaves as an amenity, not a parallel wellness engine.","What does it prove about diversification logic?":"Useful for guest spend capture and awareness, but too thin to replicate full-clinic economics.","Notes / Observations":"Better read as a resort upsell than a true clinic: high-price, low-footprint and materially reduced in scope."},{"Brand / Expression":"Pillar Wellbeing at Raffles London at The OWO","Operator / Hosted Within":"Raffles London at The OWO","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Whitehall, London, United Kingdom","Core Positioning":"Luxury Wellness Retreat","Target Segments":"HNW, Affluent Wellness, Corporate Wellness","Price Tier (1-5)":"5","Est":"2023","Description":"Pillar Wellbeing is a luxury performance and lifestyle wellness concept founded by Harry Jameson that operates the active wellness component within Raffles London at The OWO. The OWO (the restored Old War Office) reopened in September 2023 following an eight-year \u00a31.3bn redevelopment by Hinduja Group, transforming the historic building into a Raffles hotel with 120 rooms, 85 residences, restaurant\u2026","Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Individual Wellness, Corporate, High Performance","Clinical Grade (1\u20135)":"1","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"760000","Stated Wellness/Clinical Area (sq ft)":"27000","Clinical & Treatment Rooms":"5","Clinical & Treatment Rooms Detail":"Pillar Wellbeing operates the following spaces within the 27,000 sq ft multi-floor wellness facility (designed by Goddard Littlefair):\n\n\u2022 Gym \u2014 cutting-edge fitness facility equipped by Technogym, used for data-led personal coaching sessions. Hours: weekdays 06:30-21:00, weekends 08:00-20:00 (24-hour for hotel guests).\n\u2022 Movement Studio \u2014 dedicated space for group classes (HIIT, boxing, yoga, refo\u2026","No. of Specialist Facilities":"12","Specialist Facilities/Equipment":"Diagnostics & Imaging (0)\nNo MRI, CT, ultrasound, DEXA, or other clinical imaging platforms confirmed on-site. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (0)\nNo on-site phlebotomy or laboratory infrastructure documented. \n\nRegenerative / Cell Therapy Infrastructure (0)\nNo regenerative medicine or cell therapy equipment installed. \n\nIV / Infusion Infrastructure (0)\nNo dedicated IV infusion suites or infusion delivery equipment confirmed. \n\nLongevity Tech / Biohacking (5)\nVentriJect Seism\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"120","Branded Residences":"85","Total Feeder Units":"380","External Feeder Units":"0","Wellness Area per Key":"71.05263158","Revenue Drivers":"Membership-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"Pillar Kitchen (ground floor, Horse Guards Avenue entrance) \u2014 nutrition-led restaurant/caf\u00e9:\n\n\u2022 Curated by 2x Michelin-starred chef Jason Atherton in collaboration with Pillar Wellbeing nutritionists (led by Stephanie de Chillaz, Head of Nutrition)\n\u2022 Organic, locally sourced, plant-rich menu designe\u2026","Medical Licensing Model":null,"On-Site Doctors":"0","Total Specialist Count":"10","Specialist Staff Details":"Pillar Wellbeing Leadership:\n\u2022 Harry Jameson \u2014 CEO & Founder; former personal trainer to Boris Johnson; 20+ years' experience in fitness/wellbeing; runs Future Practice academy with Oliver Patrick\n\u2022 Oliver Patrick \u2014 Clinical Director; Physiologist (Birmingham Univ.); former Head of Physiology at Nuffield Health (largest team of applied physiologists in UK); co-founded Viavi on Harley Street (advan\u2026","External Doctors":"0","Specialists / 10,000 sq ft":"3.703703704","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"The OWO (Old War Office) transformation by the Hinduja Group and Onex Holding:\n\n\u2022 Acquisition: \u00a3350-374 million (Government sale, 250-year lease, 2014/2016)\n\u2022 Total investment: \u00a31.2-1.3 billion (Hinduja Group statements, Republic World 2023)\n\u2022 Development period: ~8 years (2015-2023)\n\u2022 Original buil\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Treatment","Offering Type Secondary":"Membership","No. of Programmes":"1","Programme Detail":"Pillar Wellbeing \"Transformation Programme\" (launched January 2026):\n\nDuration: 12 weeks (3 months)\nPrice: from \u00a315,500 (~$20,150) for the full programme (excl. accommodation)\n\nIncluded:\n\u2022 Personal Wellbeing Assessment: weight, body composition, cardiovascular fitness, stress levels, blood pressure, lifestyle habits\n\u2022 Dedicated wellbeing mentor as main point of contact throughout\n\u2022 Up to 3x one-to-one coaching sessions per week (movement or recovery focus)\n\u2022 Access to full group class timetable:\u2026","Minimum Programme Duration (Days)":"84","Maximum Programme Duration (Days)":"84","Minimum Programme Price ($)":"20150","Maximum Programme Price ($)":"20150","No. of \u00c0 la Carte Treatments":"18","Minimum Treatment Price ($)":"Not disclosed","Maximum Treatment Price ($)":"Not disclosed","Treatment Details":"PILLAR WELLBEING SERVICES (hotel guests, residents, members):\n\nINDIVIDUAL SESSIONS:\n\u2022 Personal Wellbeing Assessment (60 min) \u2014 weight, body composition, cardiovascular fitness, stress levels, blood pressure, lifestyle habits\n\u2022 Metabolic Analysis (60 min) \u2014 breath test for calorie/glucose metabolism\n\u2022 Personal Coaching (60 min) \u2014 tailored movement/fitness training\n\u2022 Private Yoga (60 min)\n\u2022 Shaw Method Swim Coaching (60 min) \u2014 technique-focused swimming instruction in 20m pool\n\u2022 Recovery Session (\u2026","No. of Membership Tiers":"3","Loyalty Scheme? (0/1)":"1","Membership Detail":"Pillar Wellbeing Membership at Raffles London at The OWO (limited numbers available):\n\n1. Individual Membership:\n\u2022 Annual fee: ~\u00a36,250/year (~$8,032) + joining fee ~\u00a32,000\n\u2022 Access: gym, complimentary group exercise classes, swimming pool, vitality pool, sauna, steam room, experience showers\n\u2022 Benefits: hotel dining discounts, valet parking discounts\n\u2022 Joining gift: 90-minute treatment, wearable activity tracker, personal wellbeing assessment\n\u2022 6 guest passes per year\n\n2. Joint Membership:\n\u2022 Det\u2026","Joining Fee":"2600","Minimum Membership Price ($ per month)":"669","Maximum Membership Price ($ per month)":"2678","Product/Retail? (0/1)":"0","Product/Retail Detail":"No proprietary Pillar Wellbeing product line identified.\n\n\u2022 Pillar Wellbeing app \u2014 virtual subscription for training programmes, nutrition plans, and wellness content (accessible remotely after member\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Partial room-rate integration \u2014 mixed model:\n\n\u2022 Hotel guests: complimentary access to gym, movement studio, swimming pool, vitality pool, sauna, steam room, experience showers, and group exercise classes. Gym available 24 hours for hotel guests.\n\u2022 Pillar coaching/assessments: available to hotel gues\u2026","Other Fees":"1. Valet parking: \u00a370/night\n2. Full breakfast: \u00a345/adult, \u00a322.50/child\n3. Rollaway bed: \u00a380/night\n4. Membership joining fee: ~\u00a32,000\n5. 12-week Transformation Programme: from \u00a315,500 (additional nutri\u2026","What does this brand prove about scale?":"A performance brand can gain instant scale by plugging into trophy mixed-use hospitality assets.","What does it prove about room-to-wellness ratios?":"Generous wellness space, but shared across guests, residents and members rather than a pure clinical cohort.","What does it prove about diversification logic?":"Three demand pools - residents, hotel guests, members - create resilient mixed-economy monetisation.","Notes / Observations":"Wellness layer for hotel guests, residents and members; strong for yield capture, but performance-led rather than clinical."},{"Brand / Expression":"AEON Clinic at Atlantis The Royal (Dubai, UAE)","Operator / Hosted Within":"AEON Clinic / Atlantis The Royal","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Palm Jumeirah, Dubai, United Arab Emirates","Core Positioning":"Medical Longevity","Target Segments":"UHNW, HNW, Medical Tourism","Price Tier (1-5)":"5","Est":"2023","Description":"AEON Clinic is a regenerative wellness and longevity centre founded by Dr. Jaffer Khan, located within Atlantis The Royal on Palm Jumeirah, Dubai, and opened in February 2023. Positioned as a medically led longevity clinic within a luxury hospitality setting, the concept focuses on regenerative and functional medicine approaches aimed at reversing or slowing cellular ageing.\nThe clinic integrates \u2026","Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Individual Wellness, Medical Recovery, Opportunistic Hotel Guest","Clinical Grade (1\u20135)":"3","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"1864412","Total GFA (sq ft)":"4370578","Stated Wellness/Clinical Area (sq ft)":"6800","Clinical & Treatment Rooms":"Not disclosed","Clinical & Treatment Rooms Detail":"Exact treatment room count is not publicly disclosed. ODG Architects describes the 6,800 sq ft space as featuring \"consultation rooms, treatment zones, and serene lounges\" (TikTok, Dec 2025). Grazia describes the facility as having \"dimmable glass walls\" that allow spaces to be configured between open/airy and intimate/private.\n\nBased on published service offerings, the clinic requires spaces for:\u2026","No. of Specialist Facilities":"22","Specialist Facilities/Equipment":"Diagnostics & Imaging (2)\nVisbody AI 3D body composition and posture scanner; HRV monitoring system for autonomic nervous system and stress assessment. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (1)\nOn-site phlebotomy / blood-draw station for diagnostic testing (samples sent to external laboratories rather than processed in-house). \n\nRegenerative / Cell Therapy Infrastructure (3)\n10-Pass ozone therapy system; PRP centrifuge for platelet-rich plasma preparation; plasmapheresis blood filt\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"795","Branded Residences":"231","Total Feeder Units":"205","External Feeder Units":"0","Wellness Area per Key":"71.05263158","Revenue Drivers":"Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"0","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"AEON Clinic does not operate any F&B concept. No nutrition kitchen or dedicated restaurant.\n\nWider hotel F&B at Atlantis The Royal (not operated by AEON):\n\u2022 16+ restaurants and bars, including 7 by celebrity chefs:\n  - Dinner by Heston Blumenthal (contemporary British)\n  - La Mar by Gast\u00f3n Acurio (P\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"15","Total Specialist Count":"18","Specialist Staff Details":"DOCTORS & MEDICAL SPECIALISTS (15 listed on theaeonclinic.com/specialist/):\n\n1. Dr. Jaffer Khan \u2014 Founder/Medical Director; Consultant Plastic & Reconstructive Surgeon; FRCS (Plast) UK; trained at Cork University Hospital, St Bartholomew's, Royal London Hospitals, Manhattan Eye Ear & Throat Hospital, Harley Street; first surgeon in region to pass FRCS(Plast); pioneer of facial resurfacing (introdu\u2026","External Doctors":"0","Specialists / 10,000 sq ft":"3.703703704","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"AEON Clinic capex: Not publicly disclosed. The 6,800 sq ft space was transformed by ODG Architects from a former transit lounge into a regenerative wellness clinic. Medical equipment (HBOT chamber, ozone/EBO2 system, Sciton BBL, InMode Morpheus8, Ultherapy, IV stations, laser systems) represents sig\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Treatment","Offering Type Secondary":"Consultation","No. of Programmes":"3","Programme Detail":"1. AEON Rejuvenescence Programme (Flagship Longevity Programme)\nSignature regenerative longevity programme offered in 3-, 5-, or 7-day formats, combining advanced diagnostics (DNA, epigenome and telomere testing), personalised IV infusions, HBOT, ozone therapy, photobiomodulation, peptides, exosomes, stem-cell therapies, stress-management sessions, fitness training, and spa access at Atlantis The Royal. Concludes with a longevity consultation and personalised home-care protocol. Price: not publi\u2026","Minimum Programme Duration (Days)":"2","Maximum Programme Duration (Days)":"7","Minimum Programme Price ($)":"270","Maximum Programme Price ($)":"46000","No. of \u00c0 la Carte Treatments":"65","Minimum Treatment Price ($)":"286","Maximum Treatment Price ($)":"46300","Treatment Details":"REGENERATIVE MEDICINE:\n\u2022 Mesenchymal Stem Cell Therapy (autologous & allogeneic): AED 30,000-170,000\n\u2022 Exosome Therapy: for orthopaedic injuries, anti-ageing, degenerative diseases\n\u2022 10-Pass Ozone Therapy / EBO2 (Extracorporeal Blood Oxygenation): from AED 4,500\n\u2022 Genomic Medicine: gene analysis, personalised anti-ageing protocols\n\u2022 Naturopathic Treatment: diet, exercise, stress management, self-healing\n\u2022 Functional Medicine: root cause investigation, detox, immune optimisation\n\u2022 Sports Medicine\u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"0","Membership Detail":"No membership programme identified for AEON Clinic. Services are accessed on a treatment-by-treatment or package basis.\n\nThe AEON Longevity Stay Package at Atlantis The Royal offers a hotel stay + daily treatments framework but this is a booking package, not a recurring membership.\n\nNo loyalty programme operated by AEON. Atlantis The Royal is an Accor property and participates in the ALL (Accor Live Limitless) loyalty programme for hotel stays, but this does not extend to AEON clinic services.\n\n\u2026","Joining Fee":"\u2014","Minimum Membership Price ($ per month)":"\u2014","Maximum Membership Price ($ per month)":"\u2014","Product/Retail? (0/1)":"0","Product/Retail Detail":"No proprietary AEON product/retail line identified.\n\nAEON uses premium third-party products in treatments (Juv\u00e9derm, Restylane, Ante-Age MD, Allergan, Galderma, Silhouette Soft) but does not appear to\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Partial room-rate integration via the AEON Longevity Stay Package:\n\n\u2022 30% discount on rooms, suites, and signature penthouses at Atlantis The Royal when booking the AEON Longevity Stay Package (2-5 nights)\n\u2022 Package includes daily treatments: vitamin/mineral/toxin analysis, functional medicine consu\u2026","Other Fees":"AEON Clinic:\n1. Consultation fees: Not publicly disclosed (initial consultation likely AED 500-1,000+)\n2. Diagnostic panels: Pricing varies by panel (metabolic, genomic, endocrine, etc.)\n3. Follow-up \u2026","What does this brand prove about scale?":"Regenerative longevity can live inside ultra-luxury hospitality and trade off hotel visibility.","What does it prove about room-to-wellness ratios?":"Meaningful specialist footprint, but still tiny relative to the total resort bed base.","What does it prove about diversification logic?":"Broad treatment mix but no membership; monetisation stays episodic rather than recurring.","Notes / Observations":"Premium regenerative-medicine add-on within an ultra-luxury resort: high revenue potential, but episodic and low-immersion."},{"Brand / Expression":"Longevity Health & Wellness Club at Kempinski The Boulevard (Dubai, UAE)","Operator / Hosted Within":"Longevity Wellness Worldwide / Kempinski The Boulevard","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Dubai, United Arab Emirates","Core Positioning":"Hybrid","Target Segments":"HNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2024","Description":"Longevity Health & Wellness Club is a 2,500 sqm integrated wellness and spa facility located on the 4th floor of Kempinski The Boulevard Dubai. The club operates as the hotel\u2019s primary wellness partner and is part of the Longevity Wellness Worldwide brand founded by Nazir Sacoor. In Dubai, the Longevity Health & Wellness Club concept is owned and developed by Wane Group, which introduced the brand\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Opportunistic Hotel Guest","Clinical Grade (1\u20135)":"2","Residential (0/1)":"1","Hotel Guest (0/1)":"1","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"Not disclosed","Total GFA (sq ft)":"887363","Stated Wellness/Clinical Area (sq ft)":"26910","Clinical & Treatment Rooms":"10","Clinical & Treatment Rooms Detail":"10 meticulously designed treatment rooms (per Kempinski.com and Fresha listing) across the 2,500 sqm (26,910 sq ft) 4th-floor facility. The treatment rooms support the following departments and modalities:\n\n\u2022 Medical department: consultations with international doctors (internal medicine, cardiology, sport medicine, energetic medicine)\n\u2022 Human Performance & Thermoregulation: whole body cryotherapy\u2026","No. of Specialist Facilities":"26","Specialist Facilities/Equipment":"Diagnostics & Imaging (8)\nOxidative stress assessment device; arterial stiffness & hypertension assessment system; vascular age assessment device; AGE Reader (advanced glycation end-products measurement); body composition analyser; skin collagen thickness analyser; minerals & heavy metals spectrophotometry device; medical infrared thermography system for whole-body thermal screening. \n\nLabs & Advanced Testing \u2014 Physical Infrastructure (1)\nOn-site laboratory diagnostics facility for blood draw an\u2026","External Medical Partnership?":"No formal hospital or institutional medical partnerships are publicly disclosed. The only confirmed external collaboration is with Thermography Clinic Milton, a Canadian thermography provider that operates visiting pop-up clinics within the facility, with scans analysed remotely by certified doctors\u2026","Rooms":"0","Host Hotel Rooms":"196","Branded Residences":"530","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Programme-led, Treatment-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Integrated","F&B Detail":"Longevity Health & Wellness Club operates an integrated F&B concept within its Health & Nutrition department:\n\n\u2022 Organic Press Juice Bar \u2014 on-site juice bar offering organic cold-pressed juices as part of the nutrition and detox programme\n\u2022 Light lunch included in 1-Day programmes (e.g., the Ageing \u2026","Medical Licensing Model":"Light-touch medical","On-Site Doctors":"Not disclosed","Total Specialist Count":"Not disclosed","Specialist Staff Details":"Exact staff numbers are not publicly disclosed and the facility does not publish a medical team page. Public information states the club employs international doctors across internal medicine, cardiology, sports medicine, and energetic medicine, supported by specialists in acupuncture, nutrition, osteopathy, physiotherapy, fitness, and aesthetics.\nBased on services offered, the operation likely in\u2026","External Doctors":"0","Specialists / 10,000 sq ft":null,"Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":"Longevity Health & Wellness Club capex: Not publicly disclosed. The 2,500 sqm (26,910 sq ft) facility on the 4th floor was fitted out as a spa/wellness club within the existing hotel structure. Key capital investments include:\n\u2022 CoolSculpting system (~$80,000-150,000)\n\u2022 Emsculpt NEO (~$250,000-400,0\u2026","Perceieved Capital Intensity Level (1-3)":"1","Offering Type Primary":"Programme","Offering Type Secondary":"Treatment","No. of Programmes":"5","Programme Detail":"Longevity offers 5 core programmes \u2014 Anti-Aging, Optimal Weight, Advanced Detox, Perform, and Relax \u2014 with the brochures clearly detailing the 1-day formats and pricing, while the 7-day versions are referenced more broadly but without published pricing. The brand positions 1 week as the recommended minimum for more comprehensive results. \ne558e8_19eb47512a554c4fb368b640\u2026\n\n1. Anti-Aging / \u201cAgeing Well\u201d\n1 day \u2014 AED 4,320\nIncludes ozone therapy, chiropractic adjustment, whole-body cryotherapy (\u2212110\u2026","Minimum Programme Duration (Days)":"1","Maximum Programme Duration (Days)":"7","Minimum Programme Price ($)":"885","Maximum Programme Price ($)":"1175","No. of \u00c0 la Carte Treatments":"40","Minimum Treatment Price ($)":"25","Maximum Treatment Price ($)":"2724","Treatment Details":"MEDICAL DEPARTMENT:\n\u2022 Medical consultations (internal medicine, cardiology, sport medicine, energetic medicine)\n\u2022 Diagnostic assessments\n\u2022 Ozone therapy\n\nHEALTH & NUTRITION:\n\u2022 Organic Press Juice Bar\n\u2022 Nutrition consultations\n\u2022 Food intolerance testing\n\u2022 Personalised diet programmes\n\u2022 Intensive detox cures\n\u2022 Nutrition Longevity\u00ae Academy\n\u2022 Longevity\u00ae Dietary Supplement\n\nHUMAN PERFORMANCE & THERMOREGULATION:\n\u2022 Whole body cryotherapy (-110\u00b0C)\n\u2022 Anti-gravity treadmill sessions\n\u2022 Pressotherapy (lymph\u2026","No. of Membership Tiers":"1","Loyalty Scheme? (0/1)":"0","Membership Detail":"Annual membership is available at Longevity Health & Wellness Club (confirmed via Facebook video post: \"Take the next steps on your transformative wellness journey with an annual membership\"). However, specific membership tiers, pricing, and benefits are not publicly disclosed on the website or social media. Enquiries directed to:\n\u2022 Phone: +971 52 785 6703\n\u2022 Email: info@longevitywellnessclub.com\n\nGHA DISCOVERY loyalty programme (via Kempinski Hotels / Global Hotel Alliance):\n\u2022 Hotel guests can e\u2026","Joining Fee":"Not disclosed","Minimum Membership Price ($ per month)":"Not disclosed","Maximum Membership Price ($ per month)":"Not disclosed","Product/Retail? (0/1)":"1","Product/Retail Detail":"Longevity\u00ae Dietary Supplement \u2014 listed as part of the Health & Nutrition department's offerings on longevitywellnessclub.com/departments. This appears to be a branded supplement line, though specific \u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"No specific room + wellness package has been publicly identified for Longevity at Kempinski The Boulevard Dubai.\n\nLongevity operates as the hotel's named spa partner (listed as \"Longevity Spa & Wellness\" on Kempinski.com), suggesting operational integration. However, no published package combines a \u2026","Other Fees":"Longevity Health & Wellness Club:\n1. Private Pool Rental: AED 10,000 / 4 hours (~$2,724); Summer Offer: AED 1,000 / 2 hours (~$272)\n2. Spa add-ons: Collagen Foot Mask AED 105, Collagen Hand Mask AED 1\u2026","What does this brand prove about scale?":"A wellness operator can urbanise credibly through hotel partnerships without building a destination asset.","What does it prove about room-to-wellness ratios?":"Wellness area is large enough to feel operationally serious, not just a token spa overlay.","What does it prove about diversification logic?":"Mixes programmes, treatments and membership logic, but still leans on the hotel for capture.","Notes / Observations":"Ambitious hotel-embedded hybrid with real scale, but weak medical transparency softens credibility."},{"Brand / Expression":"Sohum Wellness Sanctuary (Dubai, UAE)","Operator / Hosted Within":"Sohum Wellness Sanctuary","Level / Category":"Local \u2014 Standalone","Status":"Established","Location City, Country":"Al Quoz, Dubai, UAE","Core Positioning":"Integrative Healing","Target Segments":"HNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2024","Description":"Sohum Wellness Sanctuary is a standalone Ayurvedic wellness destination in Al Quoz, Dubai, founded by Tanya S. Mansotra and opened in November 2024. Spanning roughly 25,000 sq ft, the sanctuary blends traditional Ayurveda with modern holistic wellness practices in a purpose-built environment featuring elemental treatment rooms, yoga and meditation studios, a Himalayan salt room, landscaped gardens\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Corporate Wellness","Clinical Grade (1\u20135)":"1","Residential (0/1)":"0","Hotel Guest (0/1)":"0","Member- ship (0/1)":"1","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"1","Total Site Area (sq ft)":"25000","Total GFA (sq ft)":"25000","Stated Wellness/Clinical Area (sq ft)":"25000","Clinical & Treatment Rooms":"8","Clinical & Treatment Rooms Detail":"Sohum Wellness Sanctuary's treatment and therapy rooms are each uniquely designed by Venetian Enrico studio, themed by the five elements with distinct scent profiles, wall textures, and material palettes (per Scale Magazine, February 2026):\n\nTREATMENT ROOMS:\n1. PRITHVI (Earth) \u2014 single treatment room for Ayurvedic bodywork\n2. SURYA (Sun) \u2014 single treatment room\n3. AGNI (Fire) \u2014 single treatment ro\u2026","No. of Specialist Facilities":"0","Specialist Facilities/Equipment":"Diagnostics & Imaging (0)\nNo diagnostic imaging systems (MRI, CT, DEXA, ultrasound, or full-body scanners) confirmed on-site. \n\nLabs & Advanced Testing (0)\nNo laboratory infrastructure or blood-draw capability identified; consultations and therapist-led assessments are referenced but without clinical testing equipment. \n\nRegenerative / Cell Therapy (0)\nNo regenerative medicine infrastructure such as stem cell processing, PRP centrifuges, or cell therapy suites confirmed. \n\nIV / Infusion Infrastr\u2026","External Medical Partnership?":"No","Rooms":"0","Host Hotel Rooms":"0","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Treatment-led, Programme-led, Membership-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"TAAMA \u2014 Sohum's dedicated plant-based restaurant, open daily 11 AM-11 PM.\n\nCONCEPT: Ayurvedic-inspired, plant-based cuisine with a zero-waste philosophy and locally sourced ingredients. The dining experience extends the wellness philosophy \u2014 \"nourishment that honours both body and planet\" (per Epicu\u2026","Medical Licensing Model":"Light-touch medical","On-Site Doctors":"2","Total Specialist Count":"3","Specialist Staff Details":"Doctors: 2\nTwo confirmed DHA-licensed Ayurveda doctors \u2014 Dr. Nishana Nazeem and Dr. Abhirami Santhosh \u2014 oversee consultations and traditional Ayurvedic treatment protocols.\n\nTotal specialists: 3\nIn addition to the two doctors, the sanctuary employs one holistic wellbeing practitioner (Smitha Prasad, clinical hypnotherapy and holistic therapies). A wider team of therapists and visiting practitioner\u2026","External Doctors":"Not disclosed [no external medical partnerships or visiting physician arrangements have been publicly announced. The Ayurvedic model is delivered by in-house practitioners under Dr. Nishana Nazeem's medical directorship. Sohum does not appear to offer any Western medical services that would require external physician referrals]","Specialists / 10,000 sq ft":"1.2","Build Typology":"Urban conversion","Indicative Capex Intensity":"Sohum Wellness Sanctuary \u2014 Estimated Capital Intensity:\n\nThe 25,000 sq ft sanctuary in Al Quoz required significant investment in:\n\u2022 Full architectural design and build-out by Venetian Enrico studio\n\u2022 5+ individually designed treatment rooms with custom materials, scent profiles, and element-themed \u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Treatment","Offering Type Secondary":"Programme","No. of Programmes":"8","Programme Detail":"HOLISTIC WELLNESS RETREATS (Multi-Day Ayurveda Programmes)\n1. PANCHAKARMA DETOX PROGRAMME (3, 7 or 14 days \u2014 AED 1,850 / AED 5,350 / AED 10,000) \u2014 traditional Ayurvedic detoxification designed to cleanse the body and rebalance the doshas through herbal therapies and purification treatments.\n2. WEIGHT MANAGEMENT PROGRAMME (3, 14 or 21 days \u2014 AED 3,050 / AED 9,500 / AED 13,500) \u2014 personalised weight-loss programme combining dietary adjustments, herbal remedies and metabolic detoxification.\n3. ANTI\u2026","Minimum Programme Duration (Days)":"3","Maximum Programme Duration (Days)":"21","Minimum Programme Price ($)":"463","Maximum Programme Price ($)":"3675","No. of \u00c0 la Carte Treatments":"35","Minimum Treatment Price ($)":"82","Maximum Treatment Price ($)":"327","Treatment Details":"AYURVEDA CONSULTATION (AED 300):\n\u2022 Dosha assessment, personalised treatment plan, dietary/lifestyle guidance\n\nTRADITIONAL AYURVEDIC THERAPIES:\n\u2022 Abhyanga (AED 500/700, 60/90 min) \u2014 warm herbal oil full-body massage for rejuvenation and relaxation\n\u2022 Shiro Dhara (AED 700, 60 min) \u2014 continuous warm oil pouring on forehead; relieves stress, insomnia, mental fatigue\n\u2022 Sarvanga Dhara (AED 1,000, 90 min) \u2014 continuous pouring of medicated oil/decoction over entire body\n\u2022 Udwarthana (AED 500, 60 min) \u2014 h\u2026","No. of Membership Tiers":"1","Loyalty Scheme? (0/1)":"0","Membership Detail":"Sohum Wellness Sanctuary offers a \"bespoke membership plan, available by invitation only\" (per Zawya press release). No published membership tiers, pricing, or benefits structure is available on the website or in press materials.\n\nSESSION-BASED PACKAGES (alternative to membership):\n\u2022 5 Sessions Package: AED 3,150 (~$858) \u2014 5 x 90-min therapies, valid 3 months (effective rate: AED 630/session vs AED 700+ standard 90-min price = ~10% saving)\n\u2022 10 Sessions Package: AED 5,600 (~$1,526) \u2014 10 x 90-min\u2026","Joining Fee":"Not disclosed [membership is by invitation only; pricing is bespoke and not publicly published]","Minimum Membership Price ($ per month)":"Not disclosed [invitation-only bespoke membership; no published monthly pricing]","Maximum Membership Price ($ per month)":"Not disclosed [invitation-only bespoke membership; no published monthly pricing]","Product/Retail? (0/1)":"0","Product/Retail Detail":"No formal retail or product line confirmed at the sanctuary. Tanya Mansotra is also Founder & CEO of Plant Essence, which may supply products used in treatments, but no retail component is publicly ad\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Not applicable \u2014 Sohum Wellness Sanctuary is a standalone day sanctuary with no accommodation. There are no room rates to integrate.\n\nGuests visiting for multi-day Holistic Wellness Retreats (7-21 days) must arrange their own accommodation independently. Al Quoz is a creative/industrial district in \u2026","Other Fees":"1. WET AREA ACCESS: Complimentary for therapy guests (Steam Room, Sauna, Cold Plunge, Hot Plunge, Experience Shower) \u2014 standalone wet area access pricing not published\n2. YOGA CLASSES: Individual clas\u2026","What does this brand prove about scale?":"A strong local holistic sanctuary is possible, but scalability is not yet proven.","What does it prove about room-to-wellness ratios?":"With no rooms, all economics sit on treatment, retreat, F&B and event throughput.","What does it prove about diversification logic?":"Good in-location layering, but limited geographic or format diversification so far.","Notes / Observations":"Compelling Ayurvedic sanctuary with strong identity and F&B, but founder dependence and no accommodation constrain scale."},{"Brand / Expression":"DNA Health & Wellness at DIFC Gate Avenue (Dubai, UAE)","Operator / Hosted Within":"DNA Health & Wellness Group","Level / Category":"B \u2014 Urban Hub","Status":"Established","Location City, Country":"DIFC, Dubai, United Arab Emirates","Core Positioning":"Medical Longevity","Target Segments":"HNW, Affluent Wellness","Price Tier (1-5)":"3","Est":"2020","Description":"DNA Health & Wellness is a functional medicine and longevity clinic located in Gate Avenue at Dubai International Financial Centre, one of Dubai\u2019s main financial and professional hubs. Opened in October 2020, the clinic sits within the high-footfall Gate Avenue retail walkway and targets executives and professionals working in DIFC, operating extended hours (9am\u201310pm daily).\nThe clinic follows a f\u2026","Does the hotel have a separate spa? (0/1)":"0","Target Audiences":"Individual Wellness, Corporate Wellness, High Performance","Clinical Grade (1\u20135)":"3","Residential (0/1)":"0","Hotel Guest (0/1)":"0","Member- ship (0/1)":"0","\u00c0 la carte (0/1)":"1","Walk-Ins? (0/1)":"0","Total Site Area (sq ft)":"660000","Total GFA (sq ft)":"Undisclosed","Stated Wellness/Clinical Area (sq ft)":"Undisclosed","Clinical & Treatment Rooms":"Not disclosed [the DIFC clinic, like all DNA Health locations, has consultation rooms, IV/treatment rooms, aesthetics rooms, and blood draw stations. The extended operating hours (9am-10pm, longest in the group) suggest sufficient capacity to handle higher throughput from the DIFC business community. Wheelchair accessible entrance, parking, and restroom (per Google Maps).]","Clinical & Treatment Rooms Detail":"DNA Health DIFC Gate Avenue \u2014 Unit 103, Zone C. Individual treatment room counts are not publicly disclosed, but the service menu indicates the clinic includes:\n\nEXPECTED CLINICAL ROOMS:\n\u2022 Consultation Room(s) \u2014 for functional medicine, GP, and specialist consultations\n\u2022 IV Infusion Lounge \u2014 recliner-based IV drip administration area\n\u2022 Blood Draw Station \u2014 for health screening blood panels\n\u2022 Treat\u2026","No. of Specialist Facilities":"17","Specialist Facilities/Equipment":"Diagnostics & Imaging (3)\nECG machine for cardiac screening, InBody body composition analyser, and proprietary AI-based functional health reporting software used to interpret biomarker results.\n\nLabs & Advanced Testing (2)\nOn-site phlebotomy/blood draw station supporting biomarker panels and a PRP centrifuge for platelet-rich plasma preparation (lab analysis processed externally).\n\nRegenerative / Cell Therapy (3)\nINUSpheresis\u00ae blood filtration system, 10-pass hyperbaric ozone IV therapy system, \u2026","External Medical Partnership?":"Mubadala Health is the only publicly named clinical partner, providing advanced imaging services (Full-Body MRI, DEXA scans, and CT coronary calcium scoring) that are not available on-site at the DIFC clinic.\n\nOther external dependencies:\nLaboratory analysis (e.g. TruAge epigenetic testing, TruCheck\u2026","Rooms":"0","Host Hotel Rooms":"0","Branded Residences":"0","Total Feeder Units":"65","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Treatment-led, Programme-led","Integrated F&B Concept? (0/1)":"0","F&B Included in Programme? (0/1)":"0","Dedicated Restaurant(s) or Integrated?":null,"F&B Detail":"DNA Health & Wellness DIFC does not operate any food and beverage concept. The clinic is purely clinical/treatment-focused. The weight loss programmes include nutritional guidance and dietary planning (via clinical dietitian, AED 735 consultation) but no on-site dining.\n\nGate Avenue itself hosts num\u2026","Medical Licensing Model":"Own licence","On-Site Doctors":"1","Total Specialist Count":"3","Specialist Staff Details":"Doctors: 1 confirmed on-site\nThe DIFC clinic\u2019s Medical Director is Dr Yosef Alsaieq, a UK-trained Specialist in Family Medicine / General Practice registered with the Dubai Health Authority. He oversees clinical consultations, screening programmes, and treatment protocols at the DIFC facility.\n\nTotal specialists (on-site): ~3 (estimated)\nThe DIFC branch appears to operate with a small on-site clin\u2026","External Doctors":"12","Specialists / 10,000 sq ft":null,"Build Typology":"Urban conversion","Indicative Capex Intensity":"DNA Health & Wellness DIFC \u2014 Estimated Capital Intensity:\n\nSingle urban clinic unit (estimated 2,500-4,000 sq ft) within Gate Avenue at DIFC.\n\nCapital requirements:\n\u2022 Lease/fit-out of commercial unit within Gate Avenue (Zone C)\n\u2022 Clinical fit-out (consultation rooms, IV lounge, aesthetics suite, blo\u2026","Perceieved Capital Intensity Level (1-3)":"2","Offering Type Primary":"Treatment","Offering Type Secondary":"Consultation","No. of Programmes":"7","Programme Detail":"All programmes are available across DNA Health clinics (uniform offering). Programmes offered at DIFC:\n\nWEIGHT LOSS PROGRAMMES (via weightlossclinic.ae, led by Dr. Al Jafari):\n1. GET-IN-SHAPE (1 month, AED 3,000) \u2014 lose up to 6 kg; functional testing, bespoke plan, medical team support, nutritional programmes, supplementation\n2. BODY RESET (2 months, AED 5,500) \u2014 lose up to 9 kg; detailed functional testing, root cause analysis, weight loss injections if appropriate, weight loss IVs\n3. LIFE CHAN\u2026","Minimum Programme Duration (Days)":"30","Maximum Programme Duration (Days)":"180","Minimum Programme Price ($)":"817","Maximum Programme Price ($)":"9537","No. of \u00c0 la Carte Treatments":"63","Minimum Treatment Price ($)":"41","Maximum Treatment Price ($)":"9537","Treatment Details":"CONSULTATIONS:\n\u2022 Functional Medicine Practitioner (AED 800), Plastic Surgeon (AED 600), GP (AED 450), Acupuncturist (AED 400), Clinical Dietitian with InBody (AED 735)\n\nANNUAL HEALTH SCREENINGS:\n\u2022 Vital (33 markers, AED 800): CBC, Lipid Profile, HsCRP, liver/renal panels, HBA1c, Vitamin D3\n\u2022 Annual (57 markers, AED 1,950): adds InBody, advanced lipids (ApoA1/ApoB), insulin, thyroid (TSH/FT3/FT4/Anti-TPO), iron, zinc, folate\n\u2022 Executive (80 markers, AED 3,850): adds ECG, cancer markers, cortisol,\u2026","No. of Membership Tiers":"0","Loyalty Scheme? (0/1)":"0","Membership Detail":"DNA Health & Wellness does not operate a formal membership programme at any location, including DIFC. Revenue is transaction-based (per treatment/consultation).\n\nVOLUME DISCOUNT PACKAGES (available group-wide):\n\u2022 IV Drip Pack of 4: 40% off (e.g. 4 standard IVs for AED 3,600 vs AED 4,200 \u00e0 la carte)\n\u2022 Ozone IV 3-session pack: AED 7,560 (20% off single-session pricing)\n\u2022 Acupuncture 5-session pack: AED 1,500 (AED 300/session vs AED 350 single)\n\u2022 Stem Cell limited offers: 10% off 100M cells, 20% of\u2026","Joining Fee":"Not applicable [no membership programme]","Minimum Membership Price ($ per month)":"Not applicable [no membership programme]","Maximum Membership Price ($ per month)":"Not applicable [no membership programme]","Product/Retail? (0/1)":"0","Product/Retail Detail":"No retail or product sales component identified at the DIFC clinic or any DNA Health location. Unlike Next Health (NextHealthShop.com) or SHA (SHA Boutique with 77+ supplements), DNA Health does not s\u2026","Room Rate Integration? (0/1)":"0","Room-Rate Integration Detail":"Not applicable \u2014 DNA Health DIFC operates as a standalone clinic within a commercial walkway (Gate Avenue), not within a hotel.\n\nNEARBY HOTEL CONTEXT:\nDIFC is home to several luxury hotels within walking distance of Gate Avenue:\n\u2022 Ritz-Carlton DIFC (349 rooms)\n\u2022 Four Seasons DIFC (106 rooms)\n\u2022 Waldo\u2026","Other Fees":"1. ALL PRICES INCLUSIVE OF VAT \u2014 DNA Health states \"all prices are inclusive of VAT and any in-clinic offers\" (per rate card)\n2. NO CONSULTATION FEE for IV/treatment bookings (consultation fees apply \u2026","What does this brand prove about scale?":"Functional-medicine longevity scales well as a multi-site urban network in dense business districts.","What does it prove about room-to-wellness ratios?":"No-room clinic model optimises convenience and throughput, not immersion or residential capture.","What does it prove about diversification logic?":"Broad services and multiple sites help resilience, but no membership weakens recurrence.","Notes / Observations":"Convenient business-district longevity clinic: credible and repeatable, though retention is weaker without membership."},{"Brand / Expression":"Tulah Clinical Wellness","Operator / Hosted Within":"\u2014","Level / Category":"A \u2014 Mothership","Status":"New / Opening Soon","Location City, Country":"Kerala, India","Core Positioning":"Integrative Healing","Target Segments":"UHNW, Medical Tourism","Price Tier (1-5)":"5","Est":"2025","Description":"Tulah Kerala is a 30-acre residential clinical wellness sanctuary in Kerala, currently operating at 35 suites per Feb 2026 management commentary (while brochure materials reference 65 suites at full sanctuary scale). It combines hospital-grade diagnostics (including MRI, ICU and operating theatre capability), same-day lab turnaround and multidisciplinary care with Ayurveda and functional medicine.\u2026","Does the hotel have a separate spa? (0/1)":"\u2014","Target Audiences":"Medical Recovery, Individual Wellness, High Performance","Clinical Grade (1\u20135)":"5","Residential (0/1)":"1","Hotel Guest (0/1)":"0","Member- ship (0/1)":null,"\u00c0 la carte (0/1)":"0","Walk-Ins? (0/1)":"0","Total Site Area (sq ft)":"1307000","Total GFA (sq ft)":null,"Stated Wellness/Clinical Area (sq ft)":null,"Clinical & Treatment Rooms":"14","Clinical & Treatment Rooms Detail":"Materials indicate an 885 sqm spa with 14 wellness suites and treatment rooms, alongside hydrothermal and meditation amenities; separate materials also reference a fully equipped clinical facility with ICU, operation theatre and dedicated medical suites, but no confirmed count is given for clinical rooms specifically. 14 can be logged tentatively for wellness/treatment suites rather than clinical \u2026","No. of Specialist Facilities":"30","Specialist Facilities/Equipment":"Diagnostics & Imaging (11)\nMRI scanner; CT scanner (incl. coronary calcium scoring capability); digital X-ray unit; DEXA scanner; diagnostic ultrasound suite; ECG system; echocardiography system; sleep study / polysomnography capability; endoscopy suite; bioelectrical impedance body composition analyser; clinical skin analysis device.\n\nLabs & Advanced Testing \u2014 Physical Infrastructure (2)\nOn-site pathology & clinical laboratory (same-day turnaround capability); central sterilisation / CSSD unit \u2026","External Medical Partnership?":"Meitra Hospital, Tulah\u2019s JCI-accredited sister hospital, sits ~20 minutes away and provides overflow / specialist support. Brochures cite access to advanced imaging, medical technology and 200+ specialists when needed; the Feb 2026 transcript also describes planned surgical teams being drawn in from\u2026","Rooms":"65","Host Hotel Rooms":"\u2014","Branded Residences":"0","Total Feeder Units":"0","External Feeder Units":"0","Wellness Area per Key":null,"Revenue Drivers":"Room-led, Programme-led","Integrated F&B Concept? (0/1)":"1","F&B Included in Programme? (0/1)":"1","Dedicated Restaurant(s) or Integrated?":"Dedicated Restaurant(s)","F&B Detail":"Tulah Kerala operates two on-site restaurants within the 65-suite sanctuary, both structured around its medically guided nutrition framework rather than standalone dining concepts. Guests receive three personalised meals per day included within the room rate, with menus tailored to individual diagno\u2026","Medical Licensing Model":"Partner hospital","On-Site Doctors":null,"Total Specialist Count":"7","Specialist Staff Details":null,"External Doctors":null,"Specialists / 10,000 sq ft":null,"Build Typology":"Purpose-built clinic","Indicative Capex Intensity":"Purpose-built residential clinical wellness sanctuary with hospital-grade infrastructure including MRI, ICU and operating theatre capability, advanced diagnostics and regenerative/biotech suites \u2014 representing very high capex intensity due to full clinical and surgical build-out rather than treatmen\u2026","Perceieved Capital Intensity Level (1-3)":"3","Offering Type Primary":"Programme","Offering Type Secondary":"Consultation","No. of Programmes":"14","Programme Detail":"Pricing is room-night\u2013based rather than programme-based, with totals determined by Journey type (Wellness vs Clinical), room category, occupancy and duration.\n\nPer-night ranges are approximately:\n\u2022 $1.15k\u2013$4.0k for Wellness Journeys, and\n\u2022 $1.55k\u2013$4.7k for Clinical Journeys (excl. 18% GST).\n\nBy Journey (as correlated with their respective room nights):\n\nClinical Journeys\n1. Cardio-Respiratory Balance \u2014 14 or 21 nights \u2014 ~$23.1k or ~$81.9k\n2. Auto-Immune Balance \u2014 14 or 21 nights \u2014 ~$23.1k or ~$8\u2026","Minimum Programme Duration (Days)":"4","Maximum Programme Duration (Days)":"21","Minimum Programme Price ($)":"6400","Maximum Programme Price ($)":"81900","No. of \u00c0 la Carte Treatments":"44","Minimum Treatment Price ($)":"\u2014","Maximum Treatment Price ($)":"\u2014","Treatment Details":"Tulah references 44 named treatment modalities across the Clinical Wellness and Digital Concept brochures, spanning Ayurveda (incl. Panchakarma), bodywork, TCM, psychology, sound therapies and regenerative tech (e.g., HBOT, PRP, cryotherapy, IVs). These are delivered within personalised Wellness or Clinical Journeys rather than as a standalone menu, with selections guided by diagnostics and individual goals. The Tulah Life Index is presented as a proprietary diagnostic / progress-tracking framew\u2026","No. of Membership Tiers":null,"Loyalty Scheme? (0/1)":null,"Membership Detail":null,"Joining Fee":null,"Minimum Membership Price ($ per month)":null,"Maximum Membership Price ($ per month)":null,"Product/Retail? (0/1)":"1","Product/Retail Detail":"Protocol-led apothecary-style retail: take-home remedies and herbal products rooted in on-site medicinal gardens (incl. extensive herbal tea offering), complemented by a digital product layer (tul\u00e5h T\u2026","Room Rate Integration? (0/1)":"1","Room-Rate Integration Detail":"Tulah is effectively room-rate integrated. Guests are priced per night by Journey type, room category, occupancy and duration, but the nightly rate bundles accommodation, three personalised meals per day, doctor consultations, diagnostics / bloodwork and treatment protocols. Management says the mode\u2026","Other Fees":"1. 18% GST \u2014 added on top of room-night pricing (applies to both Wellness and Clinical Journeys).\n2. Room category upgrades \u2014 higher room types increase the per-night rate (not a separate fee, but an \u2026","What does this brand prove about scale?":"Tulah proves the core proposition is a system-led mothership, not just a wellness hotel.","What does it prove about room-to-wellness ratios?":"Low key count versus high clinical depth suggests rooms exist to contain the programme.","What does it prove about diversification logic?":"The logic is integrated journeys plus post-stay continuity; unbundling is the main dilution risk.","Notes / Observations":"Tulah is strongest as the Kerala mothership: clinically deep, programme-led, and built around integrated multi-day care."},{"Brand / Expression":"Tulah at One&Only Royal Mirage","Operator / Hosted Within":"\u2014","Level / Category":"C \u2014 Embedded / Partner","Status":"Established","Location City, Country":"Dubai, UAE","Core Positioning":null,"Target Segments":"HNW, Affluent Wellness, Medical Tourism, High Performance / Biohacker, Corporate Wellness, UHNW","Price Tier (1-5)":"4","Est":null,"Description":null,"Does the hotel have a separate spa? (0/1)":"1","Target Audiences":"Opportunistic Hotel Guest, Medical Recovery, Individual Wellness, High Performance, Family / Multi-Gen, Corporate","Clinical Grade (1\u20135)":null,"Residential (0/1)":null,"Hotel Guest (0/1)":null,"Member- ship (0/1)":null,"\u00c0 la carte (0/1)":null,"Walk-Ins? (0/1)":null,"Total Site Area (sq ft)":"2831000","Total GFA (sq ft)":"480000","Stated Wellness/Clinical Area (sq ft)":"40000","Clinical & Treatment Rooms":null,"Clinical & Treatment Rooms Detail":null,"No. of Specialist Facilities":null,"Specialist Facilities/Equipment":null,"External Medical Partnership?":null,"Rooms":"10","Host Hotel Rooms":"452","Branded Residences":"0","Total Feeder Units":"97","External Feeder Units":"95","Wellness Area per Key":"412.371134","Revenue Drivers":null,"Integrated F&B Concept? (0/1)":null,"F&B Included in Programme? (0/1)":null,"Dedicated Restaurant(s) or Integrated?":null,"F&B Detail":null,"Medical Licensing Model":null,"On-Site Doctors":null,"Total Specialist Count":null,"Specialist Staff Details":null,"External Doctors":null,"Specialists / 10,000 sq ft":"0","Build Typology":"Hotel-embedded wing","Indicative Capex Intensity":null,"Perceieved Capital Intensity Level (1-3)":null,"Offering Type Primary":null,"Offering Type Secondary":null,"No. of Programmes":null,"Programme Detail":null,"Minimum Programme Duration (Days)":null,"Maximum Programme Duration (Days)":null,"Minimum Programme Price ($)":null,"Maximum Programme Price ($)":null,"No. of \u00c0 la Carte Treatments":null,"Minimum Treatment Price ($)":null,"Maximum Treatment Price ($)":null,"Treatment Details":null,"No. of Membership Tiers":null,"Loyalty Scheme? (0/1)":null,"Membership Detail":null,"Joining Fee":null,"Minimum Membership Price ($ per month)":null,"Maximum Membership Price ($ per month)":null,"Product/Retail? (0/1)":null,"Product/Retail Detail":null,"Room Rate Integration? (0/1)":null,"Room-Rate Integration Detail":null,"Other Fees":null,"What does this brand prove about scale?":"This option proves Tulah does not automatically translate well into a resort-embedded format.","What does it prove about room-to-wellness ratios?":"Even at 40,000 sq ft, the programme would sit inside a much larger hotel ecosystem.","What does it prove about diversification logic?":"It widens format, but at the cost of model integrity - proof that not all growth is good.","Notes / Observations":"Useful as a feeder or visibility expression, but the resort format risks fragmenting Tulah unless anchored to Kerala."}]